@model ConexionSql.Models.Equipos.IbEquDto

@{
    ViewData["Title"] = "Ver Equipo - Detalles";
}

<link rel="stylesheet" href="~/css/views/crear-recepcion.css" asp-append-version="true" />

<div class="bx-card rec-screen">
    <div class="rec-screen-banner">Administración de Equipos - Consulta de Equipo</div>

    <div class="rec-screen-form">
        <!-- Código de Sistema -->
        <div class="rec-screen-head">
            <div class="rec-screen-panel">
                <div class="rec-screen-kv">
                    <div class="rec-screen-k">Código de sistema</div>
                    <div class="rec-screen-v">@Model.IbEquId</div>
                </div>
            </div>
        </div>

        <!-- Datos del Equipo - Formato de Líneas Separadas Limpio -->
        <div class="rec-screen-head" style="margin: 0 !important; padding: 0 !important; display: block !important;">
            <div class="rec-screen-table-wrap" style="margin: 0 !important; padding: 0 !important; display: block !important;">
                <div class="rec-screen-table-title" style="font-size: 0.95rem; margin: 0 !important; padding: 6px !important; display: block !important;">Datos del Equipo</div>
                <table class="rec-screen-table" style="font-size:0.9rem; border-collapse: collapse; width: 100%; margin: 0 !important; padding: 0 !important; display: table !important;">
                    <tbody>
                        <tr style="border-bottom: 1px solid #e0e0e0;">
                            <td style="width: 20%; background: #f9f9f9; padding: 6px;"><label style="margin: 0; font-weight: 500; font-size: 0.85rem;">Tipo de Equipo</label></td>
                            <td style="width: 30%; padding: 6px;"><span style="font-size: 0.85rem;">@(string.IsNullOrWhiteSpace(Model.IbEquTeqDen) ? "-" : Model.IbEquTeqDen)</span></td>
                            <td style="width: 20%; background: #f9f9f9; padding: 6px;"><label style="margin: 0; font-weight: 500; font-size: 0.85rem;">Tipo de Proceso</label></td>
                            <td style="width: 30%; padding: 6px;"><span style="font-size: 0.85rem;">@(string.IsNullOrWhiteSpace(Model.IbEquPtiDen) ? "-" : Model.IbEquPtiDen)</span></td>
                        </tr>
                        <tr style="border-bottom: 1px solid #e0e0e0;">
                            <td style="background: #f9f9f9; padding: 6px;"><label style="margin: 0; font-weight: 500; font-size: 0.85rem;">Marca</label></td>
                            <td style="padding: 6px;"><span style="font-size: 0.85rem;">@(string.IsNullOrWhiteSpace(Model.IbEquMarDen) ? "-" : Model.IbEquMarDen)</span></td>
                            <td style="background: #f9f9f9; padding: 6px;"><label style="margin: 0; font-weight: 500; font-size: 0.85rem;">Modelo</label></td>
                            <td style="padding: 6px;"><span style="font-size: 0.85rem;">@(string.IsNullOrWhiteSpace(Model.IbEquMod) ? "-" : Model.IbEquMod)</span></td>
                        </tr>
                        <tr style="border-bottom: 1px solid #e0e0e0;">
                            <td style="background: #f9f9f9; padding: 6px;"><label style="margin: 0; font-weight: 500; font-size: 0.85rem;">Serie N°</label></td>
                            <td style="padding: 6px;"><span style="font-size: 0.85rem;">@(string.IsNullOrWhiteSpace(Model.IbEquSer) ? "-" : Model.IbEquSer)</span></td>
                            <td style="background: #f9f9f9; padding: 6px;"><label style="margin: 0; font-weight: 500; font-size: 0.85rem;">Número</label></td>
                            <td style="padding: 6px;"><span style="font-size: 0.85rem;">@(Model.IbEquNum?.ToString() ?? "-")</span></td>
                        </tr>
                    </tbody>
                </table>

                <!-- Eliminar de Listados -->
                <form id="formEliminarEquipo" method="post" action="/Home/EliminarDeListados" style="margin: 0 !important;">
                    <div style="display: flex; align-items: center; padding: 6px; border-top: 1px solid #e0e0e0; background: #f9f9f9;">
                        <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; margin: 0; flex: 1;">
                            <input type="checkbox" id="chkEliminar" class="form-check-input" 
                                @(Model.IbEquOcu ? "checked" : "") 
                                onchange="document.getElementById('formEliminarEquipo').submit();" 
                                style="width: 16px; height: 16px; cursor: pointer;">
                            <span style="font-weight: 500; font-size: 0.85rem; color: #333; margin: 0;">Eliminar de Listados</span>
                        </label>
                    </div>
                    <input type="hidden" name="id" value="@Model.IbEquId">
                </form>
            </div>
        </div>

        <!-- Tab Navigation -->
        <div class="mt-3">
            <ul class="nav nav-tabs" id="equipoTabs" role="tablist" style="border-bottom: 2px solid #0d6efd;">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="ciclo-tab" data-bs-toggle="tab" data-bs-target="#ciclo-pane" type="button" role="tab" aria-controls="ciclo-pane" aria-selected="true" style="color: #666; font-weight: 500;">Ciclo de Proceso</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="especificaciones-tab" data-bs-toggle="tab" data-bs-target="#especificaciones-pane" type="button" role="tab" aria-controls="especificaciones-pane" aria-selected="false" style="color: #666; font-weight: 500;">Especificaciones del equipo</button>
                </li>
            </ul>
        </div>

        <!-- Tab Content -->
        <div class="tab-content" id="equipoTabContent" style="background: #fff; padding-top: 1rem;">
            <!-- Tab 1: Ciclo de Proceso -->
            <div class="tab-pane fade show active" id="ciclo-pane" role="tabpanel" aria-labelledby="ciclo-tab">

                <!-- Características, Consumos y Valores en 3 columnas horizontales -->
                <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0px; margin-top: 1.5rem;">
                    
                    <!-- Columna 1: Características -->
                    <div style="overflow: hidden;">
                        <div class="rec-screen-head" style="margin: 0 !important; padding: 0 !important; border-right: 1px solid #ddd !important; display: block !important;">
                            <div class="rec-screen-table-wrap" style="margin: 0 !important; padding: 0 !important; display: block !important;">
                                <div class="rec-screen-table-title" style="font-size: 0.95rem; margin: 0 !important; padding: 6px !important; display: block !important;">Características</div>
                                <table class="rec-screen-table" style="font-size:0.9rem; border-collapse: collapse; width: 100%; margin: 0 !important; padding: 0 !important; display: table !important;">
                                    <tbody>
                                        <tr style="border-bottom: 1px solid #e0e0e0;">
                                            <td style="padding: 6px; width: 55%;"><label style="font-weight: 500; font-size: 0.85rem;">Altura de cámara</label></td>
                                            <td style="padding: 6px; width: 45%;"><span style="font-size: 0.85rem;">@(Model.IbEquAlt?.ToString("F2") ?? "-") CM</span></td>
                                        </tr>
                                        <tr style="border-bottom: 1px solid #e0e0e0;">
                                            <td style="padding: 6px;"><label style="font-weight: 500; font-size: 0.85rem;">Ancho de cámara</label></td>
                                            <td style="padding: 6px;"><span style="font-size: 0.85rem;">@(Model.IbEquAnc?.ToString("F2") ?? "-") CM</span></td>
                                        </tr>
                                        <tr style="border-bottom: 1px solid #e0e0e0;">
                                            <td style="padding: 6px;"><label style="font-weight: 500; font-size: 0.85rem;">Profundidad</label></td>
                                            <td style="padding: 6px;"><span style="font-size: 0.85rem;">@(Model.IbEquPro?.ToString("F2") ?? "-") CM</span></td>
                                        </tr>
                                        <tr style="border-bottom: 1px solid #e0e0e0;">
                                            <td style="padding: 6px;"><label style="font-weight: 500; font-size: 0.85rem;">Capacidad de carga</label></td>
                                            <td style="padding: 6px;"><span style="font-size: 0.85rem;">@(Model.IbEquCag?.ToString("F2") ?? "-") Bandejas</span></td>
                                        </tr>
                                        <tr style="border-bottom: 1px solid #e0e0e0;">
                                            <td style="padding: 6px;"><label style="font-weight: 500; font-size: 0.85rem;">Profundidad 2</label></td>
                                            <td style="padding: 6px;"><span style="font-size: 0.85rem;">@(Model.IbEquPte?.ToString("F2") ?? "-") CM</span></td>
                                        </tr>
                                        <tr style="border-bottom: 1px solid #e0e0e0;">
                                            <td style="padding: 6px;"><label style="font-weight: 500; font-size: 0.85rem;">Capacidad total</label></td>
                                            <td style="padding: 6px;"><span style="font-size: 0.85rem;">@(Model.IbEquCap?.ToString("F2") ?? "-") Cm3</span></td>
                                        </tr>
                                        <tr style="border-bottom: 1px solid #e0e0e0;">
                                            <td style="padding: 6px;"><label style="font-weight: 500; font-size: 0.85rem;">Porcentaje de cámara</label></td>
                                            <td style="padding: 6px;"><span style="font-size: 0.85rem;">@(Model.IbEquPorc?.ToString("F2") ?? "-") %</span></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 6px;"><label style="font-weight: 500; font-size: 0.85rem;">Capacidad útil</label></td>
                                            <td style="padding: 6px;"><span style="font-size: 0.85rem;">@(Model.IbEquCapu?.ToString("F2") ?? "-") Cm3</span></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Columna 2: Consumos del equipo -->
                    <div style="overflow: hidden;">
                        <div class="rec-screen-head" style="margin: 0 !important; padding: 0 !important; border-right: 1px solid #ddd !important; display: block !important;">
                            <div class="rec-screen-table-wrap" style="margin: 0 !important; padding: 0 !important; display: block !important;">
                                <div class="rec-screen-table-title" style="font-size: 0.95rem; margin: 0 !important; padding: 6px !important; display: block !important;">Consumos del equipo</div>
                                <table class="rec-screen-table" style="font-size:0.9rem; border-collapse: collapse; width: 100%; margin: 0 !important; padding: 0 !important; display: table !important;">
                                    <tbody>
                                        <tr style="border-bottom: 1px solid #e0e0e0;">
                                            <td style="padding: 6px; width: 55%;"><label style="font-weight: 500; font-size: 0.85rem;">Agua</label></td>
                                            <td style="padding: 6px; width: 45%;"><span style="font-size: 0.85rem;">@(Model.IbEquCag?.ToString("F2") ?? "-") LTS</span></td>
                                        </tr>
                                        <tr style="border-bottom: 1px solid #e0e0e0;">
                                            <td style="padding: 6px;"><label style="font-weight: 500; font-size: 0.85rem;">Aire</label></td>
                                            <td style="padding: 6px;"><span style="font-size: 0.85rem;">@(Model.IbEquCai ?? "-") LTS</span></td>
                                        </tr>
                                        <tr style="border-bottom: 1px solid #e0e0e0;">
                                            <td style="padding: 6px;"><label style="font-weight: 500; font-size: 0.85rem;">Electricidad</label></td>
                                            <td style="padding: 6px;"><span style="font-size: 0.85rem;">@(Model.IbEquCel?.ToString("F2") ?? "-") KW</span></td>
                                        </tr>
                                        <tr style="border-bottom: 1px solid #e0e0e0;">
                                            <td style="padding: 6px;"><label style="font-weight: 500; font-size: 0.85rem;">Esterilizante</label></td>
                                            <td style="padding: 6px;"><span style="font-size: 0.85rem;">@(Model.IbEquCes?.ToString("F2") ?? "-") UNID</span></td>
                                        </tr>
                                        <tr style="border-bottom: 1px solid #e0e0e0;">
                                            <td style="padding: 6px;"><label style="font-weight: 500; font-size: 0.85rem;">Controles</label></td>
                                            <td style="padding: 6px;"><span style="font-size: 0.85rem;">@(Model.IbEquPco?.ToString("F2") ?? "-") UNID</span></td>
                                        </tr>
                                        <tr style="border-bottom: 1px solid #e0e0e0;">
                                            <td style="padding: 6px;"><label style="font-weight: 500; font-size: 0.85rem;">Lbs/Hora</label></td>
                                            <td style="padding: 6px;"><span style="font-size: 0.85rem;">@(Model.IbEquCagCant?.ToString("F2") ?? "-") $ 0</span></td>
                                        </tr>
                                        <tr style="border-bottom: 1px solid #e0e0e0;">
                                            <td style="padding: 6px;"><label style="font-weight: 500; font-size: 0.85rem;">Li/Hora</label></td>
                                            <td style="padding: 6px;"><span style="font-size: 0.85rem;">@(Model.IbEquCaiCant?.ToString("F2") ?? "-") $ 0</span></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 6px;"><label style="font-weight: 500; font-size: 0.85rem;">KW/H</label></td>
                                            <td style="padding: 6px;"><span style="font-size: 0.85rem;">@(Model.IbEquCelCant?.ToString("F2") ?? "-") $ 0</span></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Columna 3: Valores del proceso -->
                    <div style="overflow: hidden;">
                        <div class="rec-screen-head" style="margin: 0 !important; padding: 0 !important; border: 0 !important; display: block !important;">
                            <div class="rec-screen-table-wrap" style="margin: 0 !important; padding: 0 !important; display: block !important;">
                                <div class="rec-screen-table-title" style="font-size: 0.95rem; margin: 0 !important; padding: 6px !important; display: block !important;">Valores del proceso</div>
                                <table class="rec-screen-table" style="font-size:0.9rem; border-collapse: collapse; width: 100%; margin: 0 !important; padding: 0 !important; display: table !important;">
                                    <tbody>
                                        <tr style="border-bottom: 1px solid #e0e0e0;">
                                            <td style="padding: 6px; width: 55%;"><label style="font-weight: 500; font-size: 0.85rem;">Costo de proceso</label></td>
                                            <td style="padding: 6px; width: 45%;"><span style="font-size: 0.85rem;">@(Model.IbEquPco?.ToString("F2") ?? "-") $</span></td>
                                        </tr>
                                        <tr style="border-bottom: 1px solid #e0e0e0;">
                                            <td style="padding: 6px;"><label style="font-weight: 500; font-size: 0.85rem;">Coef. ganancia</label></td>
                                            <td style="padding: 6px;"><span style="font-size: 0.85rem;">@(Model.IbEquPorc?.ToString("F2") ?? "-") %</span></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 6px;"><label style="font-weight: 500; font-size: 0.85rem;">Precio de venta</label></td>
                                            <td style="padding: 6px;"><span style="font-size: 0.85rem;">@(Model.IbEquPve?.ToString("F2") ?? "-") $</span></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab 2: Especificaciones del equipo -->
            <div class="tab-pane fade" id="especificaciones-pane" role="tabpanel" aria-labelledby="especificaciones-tab">
                <div class="rec-screen-head" style="margin: 0 !important; padding: 0 !important; display: block !important;">
                    <div class="rec-screen-table-wrap" style="margin: 0 !important; padding: 0 !important; display: block !important;">
                        <table class="rec-screen-table" style="font-size:0.9rem; border-collapse: collapse; width: 100%; margin: 0 !important; padding: 0 !important; display: table !important;">
                            <thead>
                                <tr style="background: #f5f5f5; border-bottom: 1px solid #e0e0e0;">
                                    <th style="padding: 6px; width: 40%; font-weight: 600; text-align: left; font-size: 0.85rem;">Tipo de ciclo</th>
                                    <th style="padding: 6px; width: 40%; font-weight: 600; text-align: left; font-size: 0.85rem;">Volumen en cámara</th>
                                    <th style="padding: 6px; width: 20%; font-weight: 600; text-align: center; font-size: 0.85rem;">Eliminar</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Fila 1: Datos actuales del equipo -->
                                <tr style="border-bottom: 1px solid #e0e0e0;">
                                    <td style="padding: 6px;">
                                        <select class="form-control form-control-sm" style="font-size: 0.85rem; border: 1px solid #ddd; padding: 4px;">
                                            <option value="">@(string.IsNullOrWhiteSpace(Model.IbEquPtiDen) ? "-" : Model.IbEquPtiDen)</option>
                                            <option value="VAPOR">VAPOR</option>
                                            <option value="GAS">GAS</option>
                                            <option value="ÓXIDO_ETILENO">ÓXIDO ETILENO</option>
                                            <option value="OTRO">OTRO</option>
                                        </select>
                                    </td>
                                    <td style="padding: 6px;">
                                        <input type="number" step="0.01" class="form-control form-control-sm" value="@(Model.IbEquCap?.ToString("F2") ?? "")" style="font-size: 0.85rem; border: 1px solid #ddd; padding: 4px;" />
                                    </td>
                                    <td style="padding: 6px; text-align: center;">
                                        <input type="checkbox" @(Model.IbEquOcu ? "checked" : "") style="width: 16px; height: 16px; cursor: pointer;" />
                                    </td>
                                </tr>
                                <!-- Fila 2: Agregar nueva especificación -->
                                <tr style="border-bottom: 1px solid #e0e0e0;">
                                    <td style="padding: 6px;">
                                        <select class="form-control form-control-sm" style="font-size: 0.85rem; border: 1px solid #ddd; padding: 4px;">
                                            <option value="">Seleccionar...</option>
                                            <option value="VAPOR">VAPOR</option>
                                            <option value="GAS">GAS</option>
                                            <option value="ÓXIDO_ETILENO">ÓXIDO ETILENO</option>
                                            <option value="OTRO">OTRO</option>
                                        </select>
                                    </td>
                                    <td style="padding: 6px;">
                                        <input type="number" step="0.01" class="form-control form-control-sm" style="font-size: 0.85rem; border: 1px solid #ddd; padding: 4px;" />
                                    </td>
                                    <td style="padding: 6px; text-align: center;">
                                        <button type="button" class="btn btn-sm btn-primary" style="padding: 4px 12px; font-size: 0.85rem;">Agregar</button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Botones de Acción -->
        <div class="rec-screen-actions mt-4" style="display: flex; gap: 10px; justify-content: flex-end;">
            <a href="/Home/AreaSistema?tipo=equipos" class="btn btn-outline-primary btn-sm px-4">Cerrar</a>
            <button type="button" class="btn btn-secondary btn-sm px-4" id="btnImprimir">Imprimir</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const btnImprimir = document.getElementById('btnImprimir');
            if (btnImprimir) {
                btnImprimir.addEventListener('click', function () {
                    window.print();
                });
            }
        });
    </script>
}
