@model IEnumerable<ConexionSql.Models.IbPer.IbPerDto>

<link rel="stylesheet" href="~/css/views/crear-recepcion.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/views/info-basica.css" asp-append-version="true" />

<div class="rec-screen">

    <div class="rec-screen-banner">
        Información Básica - Personal
    </div>
    <div class="rec-screen-kv" style="max-width:500px; margin-bottom:10px;">
    
        <div class="rec-screen-k">Buscar</div>

        <div class="rec-screen-v">
            <input type="text"
                   id="buscarPersonal"
                   class="form-control"
                   placeholder="Por nombre o apellido..." />
        </div>

    </div>

    <div class="rec-screen-actions mb-2">
        <a asp-controller="IbPer" asp-action="InsertIbPer" class="btn btn-baxen">
            Nuevo
        </a>

        <a asp-controller="IbPer" asp-action="IbPerEdit" class="btn btn-baxen">
            Editar
        </a>
    </div>

    <div class="rec-screen-table-wrap" style="height:550px; overflow:auto;">
        <table class="rec-screen-table">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Apellido</th>
                    <th>Nombre</th>
                    <th>Cargo</th>
                    <th>Sector</th>
                    <th>Inhabilitado</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var p in Model)
                    {
                        <tr>
                            <td>@p.IbPerId.ToString("D5")</td>
                            <td>@p.IbPerApe</td>
                            <td>@p.IbPerNom</td>
                            <td>@(string.IsNullOrEmpty(p.IbPerCarDen) ? "-" : p.IbPerCarDen)</td>
                            <td>@(string.IsNullOrEmpty(p.IbSecDen) ? "-" : p.IbSecDen)</td>
                            <td style="text-align:center;">
                                <input type="checkbox" disabled @(p.IbPerOcu == true ? "checked" : "") />
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="rec-screen-note">
                            No hay registros disponibles.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>
<div class="info-basica-footer-fixed">
    @await Html.PartialAsync("~/Views/Shared/_BotonesInfoBasica.cshtml")
</div>

<script>
    document.getElementById('buscarPersonal').addEventListener('keyup', function () {

        let filtro = this.value.toLowerCase();
        let filas = document.querySelectorAll('.rec-screen-table tbody tr');

        filas.forEach(function (fila) {
            let texto = fila.innerText.toLowerCase();
            fila.style.display = texto.includes(filtro) ? '' : 'none';
        });

    });
</script>