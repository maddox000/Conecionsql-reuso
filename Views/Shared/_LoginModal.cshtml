<div class="modal fade" id="loginTareasModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Validación de acceso</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="mb-3">
                    <label>Nombre</label>
                    <input type="text" class="form-control" id="loginNombre" autocomplete="off" />

                    <!-- LISTA DE RESULTADOS -->
                    <div id="listaUsuarios" class="list-group mt-2"></div>

                    <!-- ID OCULTO DEL USUARIO -->
                    <input type="hidden" id="loginUsuarioId" />
                </div>

                <div class="mb-3">
                    <label>Clave</label>
                    <input type="password" class="form-control" id="loginClave" />
                </div>

                <div id="loginMensaje" class="text-danger"></div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button class="btn btn-primary" id="btnValidarLogin">Ingresar</button>
            </div>

        </div>
    </div>
</div>


