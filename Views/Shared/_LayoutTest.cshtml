<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DAT</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Estilos personalizados -->
    <link rel="stylesheet" href="~/css/estilos.css" asp-append-version="true" />
</head>
<body>

    <!-- MENÚ LATERAL IZQUIERDO -->
    <aside class="menu-lateral">
        <ul class="menu-lista">

            <!-- BÚSQUEDA -->
            <li class="menu-item">
                <button type="button" class="menu-titulo toggle-submenu">Búsqueda</button>
                <ul class="submenu">
                    <li><a asp-controller="IbPer" asp-action="Index">Ver Personal</a></li>
                    <li><a asp-controller="Procesos" asp-action="BuscarProcesos">Buscar Procesos</a></li>
                    <li><a asp-controller="Busquedas" asp-action="BusquedasFecha">Buscar Recepciones</a></li>
                </ul>
            </li>

            <!-- TAREAS -->
            <li class="menu-item">
                <button type="button" class="menu-titulo toggle-submenu">Tareas</button>
                <ul class="submenu">

                    <!-- 🔥 ESTE ABRE EL LOGIN -->
                    <li><a href="#" id="btnRecepcion">Recepciones</a></li>

                    <li><a href="#" id="btnLavado">Lavado</a></li>
                    <li><a href="#" id="btnAcondicionado">Acondicionado</a></li>
                    <li><a href="#" id="btnProcesos">Procesos</a></li>
                    <li><a href="#" id="btnEntrega">Entregas</a></li>
                </ul>
            </li>
        </ul>
    </aside>

    <!-- NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3" style="margin-left: 200px;">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <img src="~/img/logo.png" style="height: 60px;" />
                </a>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <!-- CONTENIDO -->
    <main class="contenido">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - DAT
        </div>
    </footer>

    <!-- LIBRERÍAS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- MENÚ LATERAL -->
    <script>
            document.addEventListener("DOMContentLoaded", function () {
                const botones = document.querySelectorAll(".toggle-submenu");

                botones.forEach(boton => {
                    boton.addEventListener("click", function () {
                        const submenu = this.nextElementSibling;

                        document.querySelectorAll(".submenu").forEach(sm => {
                            if (sm !== submenu) sm.classList.remove("visible");
                        });

                        submenu.classList.toggle("visible");
                    });
                });
            });
    </script>

    <!-- 🔥 MODAL LOGIN -->
    <partial name="_LoginModal" />

    <!-- 🔥 TU LOGIN CENTRALIZADO -->
    <script src="~/js/login.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>