@model ConexionSql.Models.Recepciones.TbRec
@using ConexionSql.Models.IbPer
@using ConexionSql.Models.Sectores
@using ConexionSql.Models.Recepciones

@{
    ViewData["Title"] = "Nueva Recepción";
    var listaSectores = ViewBag.ListaSectores as List<IbSec>;
    var subFormModel = ViewBag.SubFormularioDetalle as TbRecDetFormDto;
}

<h2>Nueva Recepción</h2>

<form asp-action="CrearRecepcion" method="post">
    @Html.AntiForgeryToken()

    <!-- 🔹 FILA SUPERIOR: NÚMERO + FECHA + HORA -->
    <div class="row mb-3">

        <div class="col-md-2">
            <label>Número recepción</label>
            <input type="text" class="form-control"
                   value="@(Model != null && Model.TbRecId > 0 ? Model.TbRecId.ToString() : "")"
                   readonly />
        </div>

        <div class="col-md-2">
            <label>Fecha</label>
            <input type="text" class="form-control"
                   value="@(Model?.TbRecFec?.ToString("dd/MM/yyyy") ?? "")"
                   readonly />
        </div>

        <div class="col-md-2">
            <label>Hora</label>
            <input type="text" class="form-control"
                   value="@(Model?.TbRecHorIni?.ToString("HH:mm") ?? "")"
                   readonly />
        </div>

        <!-- 🏭 Sectores a la derecha -->
        <div class="col-md-3">
            <label for="TbRecSecOriBusqueda">Sector Origen</label>

            <input type="text"
                   id="TbRecSecOriBusqueda"
                   class="form-control"
                   autocomplete="off"
                   value="@(listaSectores?.FirstOrDefault(x => x.IbSecId == Model?.TbRecSecOriId)?.IbSecDen ?? "")" />

            <div id="listaSectoresOrigen" class="list-group mt-2"></div>

            <input type="hidden" asp-for="TbRecSecOriId" id="TbRecSecOriId" />
        </div>

        <div class="col-md-3">
            <label for="TbRecSecDesBusqueda">Sector Destino</label>

            <input type="text"
                   id="TbRecSecDesBusqueda"
                   class="form-control"
                   autocomplete="off"
                   value="@(listaSectores?.FirstOrDefault(x => x.IbSecId == Model?.TbRecSecDesId)?.IbSecDen ?? "")" />

            <div id="listaSectoresDestino" class="list-group mt-2"></div>

            <input type="hidden" asp-for="TbRecSecDesId" id="TbRecSecDesId" />
        </div>
    </div>

    <!-- 🔹 FILA 2: USUARIO + TOTAL -->
    <div class="row mb-3">

        <div class="col-md-4">
            <label>Usuario</label>
            <input type="text" class="form-control"
                   value="@ViewBag.UsuarioLogueado"
                   readonly />
        </div>

        <div class="col-md-2">
            <label>Total recibido</label>
            <input type="text" id="TbRecCantTot" class="form-control"
                   value="@(Model?.TbRecCantTot ?? 0)"
                   readonly />
        </div>

    </div>

    <button type="submit" class="btn btn-primary mt-3">Guardar Recepción</button>
</form>

@if (Model != null && Model.TbRecId > 0 && subFormModel != null)
{
    subFormModel.Detalle ??= new TbRecDetDto();
    subFormModel.Detalle.TB_REC_ID = Model.TbRecId;

    <div class="mt-4">
        <h4>Agregar Material</h4>
        @await Html.PartialAsync("_SubFormRecDet", subFormModel)
    </div>
}

@section Scripts {

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const sectores = [
                @if (listaSectores != null)
                {
                        for (int i = 0; i < listaSectores.Count; i++)
                        {
                                var s = listaSectores[i];
                                @:{ id: @s.IbSecId, den: "@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(s.IbSecDen ?? ""))" }@(i < listaSectores.Count - 1 ? "," : "")
                        }
                }
            ];

            const inputSectorDestino = document.getElementById("TbRecSecDesBusqueda");
            const hiddenSectorDestino = document.getElementById("TbRecSecDesId");
            const listaSectoresDestino = document.getElementById("listaSectoresDestino");

            const inputSectorOrigen = document.getElementById("TbRecSecOriBusqueda");
            const hiddenSectorOrigen = document.getElementById("TbRecSecOriId");
            const listaSectoresOrigen = document.getElementById("listaSectoresOrigen");

            if (inputSectorOrigen) {
            inputSectorOrigen.focus();
            inputSectorOrigen.select();
        }

            let sectoresDestinoFiltrados = [];
            let indiceDestino = -1;

            let sectoresOrigenFiltrados = [];
            let indiceOrigen = -1;

            // ================= DESTINO =================

            function renderDestino(items) {
                sectoresDestinoFiltrados = items || [];
                listaSectoresDestino.innerHTML = "";

                if (!items.length) {
                    listaSectoresDestino.style.display = "none";
                    return;
                }

                items.forEach((sec, i) => {
                    const item = document.createElement("button");
                    item.type = "button";
                    item.className = "list-group-item list-group-item-action";
                    item.textContent = sec.den;

                    if (i === indiceDestino) item.classList.add("active");

                    item.onclick = () => {
                        inputSectorDestino.value = sec.den;
                        hiddenSectorDestino.value = sec.id;
                        listaSectoresDestino.style.display = "none";
                        hiddenSectorDestino.form.submit();
                    };

                    listaSectoresDestino.appendChild(item);
                });

                listaSectoresDestino.style.display = "block";
            }

            if (inputSectorDestino) {

                inputSectorDestino.addEventListener("focus", () => {
                    indiceDestino = -1;
                    renderDestino(sectores);
                });

                inputSectorDestino.addEventListener("input", function () {
                    indiceDestino = -1;
                    hiddenSectorDestino.value = "";

                    const filtrados = sectores.filter(x =>
                        x.den.toLowerCase().includes(this.value.toLowerCase())
                    );

                    renderDestino(filtrados);
                });

                inputSectorDestino.addEventListener("keydown", function (e) {

                    if (e.key === "ArrowDown") {
                        e.preventDefault();
                        indiceDestino = (indiceDestino + 1) % sectoresDestinoFiltrados.length;
                        renderDestino(sectoresDestinoFiltrados);
                    }

                    if (e.key === "ArrowUp") {
                        e.preventDefault();
                        indiceDestino = (indiceDestino - 1 + sectoresDestinoFiltrados.length) % sectoresDestinoFiltrados.length;
                        renderDestino(sectoresDestinoFiltrados);
                    }

                if (e.key === "Enter") {
                e.preventDefault();

                const textoActual = (inputSectorDestino.value || "").trim();

                // 🔥 1. si ya viene de ORIGEN (o ya tiene valor válido) → guardar directo
                if (hiddenSectorDestino.value && textoActual !== "") {
                    listaSectoresDestino.style.display = "none";
                    hiddenSectorDestino.form.submit();
                    return;
                }

                // 🔥 2. si usó flechas
                if (indiceDestino >= 0 && sectoresDestinoFiltrados.length > 0) {
                    const sel = sectoresDestinoFiltrados[indiceDestino];
                    hiddenSectorDestino.value = sel.id;
                    inputSectorDestino.value = sel.den;
                    listaSectoresDestino.style.display = "none";
                    hiddenSectorDestino.form.submit();
                    return;
                }

                // 🔥 3. si escribió exacto
                const exacto = sectores.find(x =>
                    x.den.toLowerCase() === textoActual.toLowerCase()
                );

                if (exacto) {
                    hiddenSectorDestino.value = exacto.id;
                    inputSectorDestino.value = exacto.den;
                    listaSectoresDestino.style.display = "none";
                    hiddenSectorDestino.form.submit();
                }
            }
                });
            }

            // ================= ORIGEN =================

            function renderOrigen(items) {
                sectoresOrigenFiltrados = items || [];
                listaSectoresOrigen.innerHTML = "";

                if (!items.length) {
                    listaSectoresOrigen.style.display = "none";
                    return;
                }

                items.forEach((sec, i) => {
                    const item = document.createElement("button");
                    item.type = "button";
                    item.className = "list-group-item list-group-item-action";
                    item.textContent = sec.den;

                    if (i === indiceOrigen) item.classList.add("active");

                    item.onclick = () => seleccionarOrigen(sec);

                    listaSectoresOrigen.appendChild(item);
                });

                listaSectoresOrigen.style.display = "block";
            }

            function seleccionarOrigen(sec) {
                inputSectorOrigen.value = sec.den;
                hiddenSectorOrigen.value = sec.id;

                // copiar a destino
                inputSectorDestino.value = sec.den;
                hiddenSectorDestino.value = sec.id;

                listaSectoresOrigen.style.display = "none";

                inputSectorDestino.focus();
                inputSectorDestino.select();
            }

            if (inputSectorOrigen) {

                inputSectorOrigen.addEventListener("focus", () => {
                    indiceOrigen = -1;
                    renderOrigen(sectores);
                });

                inputSectorOrigen.addEventListener("click", () => { indiceOrigen = -1; renderOrigen(sectores); });

                inputSectorOrigen.addEventListener("input", function () {
                    indiceOrigen = -1;
                    hiddenSectorOrigen.value = "";

                    const filtrados = sectores.filter(x =>
                        x.den.toLowerCase().includes(this.value.toLowerCase())
                    );

                    renderOrigen(filtrados);
                });

                inputSectorOrigen.addEventListener("keydown", function (e) {

                    if (e.key === "ArrowDown") {
                        e.preventDefault();
                        indiceOrigen = (indiceOrigen + 1) % sectoresOrigenFiltrados.length;
                        renderOrigen(sectoresOrigenFiltrados);
                    }

                    if (e.key === "ArrowUp") {
                        e.preventDefault();
                        indiceOrigen = (indiceOrigen - 1 + sectoresOrigenFiltrados.length) % sectoresOrigenFiltrados.length;
                        renderOrigen(sectoresOrigenFiltrados);
                    }

                    if (e.key === "Enter") {
                        e.preventDefault();

                        if (indiceOrigen >= 0) {
                            seleccionarOrigen(sectoresOrigenFiltrados[indiceOrigen]);
                        }
                    }
                });
            }

            // cerrar listas
            document.addEventListener("click", function (e) {
                if (!inputSectorDestino.contains(e.target) && !listaSectoresDestino.contains(e.target)) {
                    listaSectoresDestino.style.display = "none";
                }
                if (!inputSectorOrigen.contains(e.target) && !listaSectoresOrigen.contains(e.target)) {
                    listaSectoresOrigen.style.display = "none";
                }
            });

        });
    </script>

    @if (Model != null && Model.TbRecId > 0)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const inputCodigo = document.getElementById("TB_REC_DET_MAT_PR");
                if (inputCodigo) {
                    setTimeout(() => {
                        inputCodigo.focus();
                        inputCodigo.select();
                    }, 200);
                }
            });
        </script>
    }

}