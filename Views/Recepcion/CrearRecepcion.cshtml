@model ConexionSql.Models.Recepciones.TbRec
@using ConexionSql.Models.IbPer
@using ConexionSql.Models.Sectores
@using ConexionSql.Models.Recepciones

@{
    ViewData["Title"] = "Nueva Recepción";
    var listaSectores = ViewBag.ListaSectores as List<IbSec>;
    var subFormModel = ViewBag.SubFormularioDetalle as TbRecDetFormDto;
}

<h2>Nueva Recepción</h2>

<form asp-action="CrearRecepcion" method="post">
    @Html.AntiForgeryToken()

    <!-- 🔹 FILA SUPERIOR: NÚMERO + FECHA + HORA -->
    <div class="row mb-3">

        <div class="col-md-2">
            <label>Número recepción</label>
            <input type="text" class="form-control"
                   value="@(Model != null && Model.TbRecId > 0 ? Model.TbRecId.ToString() : "")"
                   readonly />
        </div>

        <div class="col-md-2">
            <label>Fecha</label>
            <input type="text" class="form-control"
                   value="@(Model?.TbRecFec?.ToString("dd/MM/yyyy") ?? "")"
                   readonly />
        </div>

        <div class="col-md-2">
            <label>Hora</label>
            <input type="text" class="form-control"
                   value="@(Model?.TbRecHorIni?.ToString("HH:mm") ?? "")"
                   readonly />
        </div>

        <!-- 🏭 Sectores a la derecha -->
        <div class="col-md-3">
            <label for="TbRecSecOriId">Sector Origen</label>
            <select asp-for="TbRecSecOriId" class="form-control">
                <option value="">-- Seleccione --</option>
                @if (listaSectores != null)
                {
                    @foreach (var s in listaSectores)
                    {
                        <option value="@s.IbSecId">@s.IbSecDen</option>
                    }
                }
            </select>
        </div>

        <div class="col-md-3">
            <label for="TbRecSecDesId">Sector Destino</label>
            <select asp-for="TbRecSecDesId" class="form-control">
                <option value="">-- Seleccione --</option>
                @if (listaSectores != null)
                {
                    @foreach (var s in listaSectores)
                    {
                        <option value="@s.IbSecId">@s.IbSecDen</option>
                    }
                }
            </select>
        </div>
    </div>

    <!-- 🔹 FILA 2: USUARIO + TOTAL -->
    <div class="row mb-3">

        <div class="col-md-4">
            <label>Usuario</label>
            <input type="text" class="form-control"
                   value="@ViewBag.UsuarioLogueado"
                   readonly />
        </div>

        <div class="col-md-2">
            <label>Total recibido</label>
            <input type="text" class="form-control"
                   value="@(Model?.TbRecCantTot ?? 0)"
                   readonly />
        </div>

    </div>

    <button type="submit" class="btn btn-primary mt-3">Guardar Recepción</button>
</form>

@if (Model != null && Model.TbRecId > 0 && subFormModel != null)
{
    subFormModel.Detalle ??= new TbRecDetDto();
    subFormModel.Detalle.TB_REC_ID = Model.TbRecId;

    <div class="mt-4">
        <h4>Agregar Material</h4>
        @await Html.PartialAsync("_SubFormRecDet", subFormModel)
    </div>
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const sectorDestino = document.getElementById("TbRecSecDesId");

            if (sectorDestino) {
                sectorDestino.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") {
                        e.preventDefault();
                        this.form.submit();
                    }
                });

                sectorDestino.addEventListener("blur", function () {
                    if (this.value) {
                        this.form.submit();
                    }
                });
            }
        });
    </script>
}