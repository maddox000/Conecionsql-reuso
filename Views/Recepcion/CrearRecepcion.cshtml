@model ConexionSql.Models.Recepciones.TbRec
@using ConexionSql.Models.IbPer
@using ConexionSql.Models.Sectores
@using ConexionSql.Models.Recepciones

@{
    
    

    
    var listaSectores = ViewBag.ListaSectores as List<IbSec>;
    var subFormModel = ViewBag.SubFormularioDetalle as TbRecDetFormDto;

    var numeroRecepcion = Model != null && Model.TbRecId > 0 ? Model.TbRecId.ToString() : "Pendiente";
    var fechaRecepcion = Model?.TbRecFec?.ToString("dd/MM/yyyy") ?? DateTime.Now.ToString("dd/MM/yyyy");
    var horaRecepcion = Model?.TbRecHorIni?.ToString("HH:mm") ?? DateTime.Now.ToString("HH:mm");
    var sectorOrigenTexto = listaSectores?.FirstOrDefault(x => x.IbSecId == Model?.TbRecSecOriId)?.IbSecDen ?? "";
    var sectorDestinoTexto = listaSectores?.FirstOrDefault(x => x.IbSecId == Model?.TbRecSecDesId)?.IbSecDen ?? "";
    var usuarioLogueado = ViewBag.UsuarioLogueado ?? "NO REGISTRADO";
    var totalRecibido = Model?.TbRecCantTot ?? 0;
}

<link rel="stylesheet" href="~/css/views/crear-recepcion.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/views/info-basica.css" asp-append-version="true" />

<div class="bx-card rec-screen">
    <div class="rec-screen-banner">Recepcion de materiales</div>

    <form asp-action="CrearRecepcion" method="post">
        @Html.AntiForgeryToken()

        <div class="rec-screen-head">
            <div class="rec-screen-panel">
                <div class="rec-screen-kv">
                    <div class="rec-screen-k">Numero de recepcion</div>
                    <div class="rec-screen-v">@numeroRecepcion</div>
                </div>

                <div class="rec-screen-kv">
                    <div class="rec-screen-k">Fecha</div>
                    <div class="rec-screen-v">@fechaRecepcion</div>
                </div>

                <div class="rec-screen-kv">
                    <div class="rec-screen-k">Hora</div>
                    <div class="rec-screen-v">@horaRecepcion</div>
                </div>

                <div class="rec-screen-kv">
                    <div class="rec-screen-k">Usuario</div>
                    <div class="rec-screen-v">@usuarioLogueado</div>
                </div>
            </div>

            <div class="rec-screen-panel">
                <div class="rec-screen-kv">
                    <div class="rec-screen-k">Sector Origen</div>

                    <div class="rec-screen-v" style="flex-direction: column; align-items: stretch;">
                        <input type="text"
                               id="TbRecSecOriBusqueda"
                               class="form-control"
                               autocomplete="off"
                               value="@(listaSectores?.FirstOrDefault(x => x.IbSecId == Model?.TbRecSecOriId)?.IbSecDen ?? "")" />

                        <div id="listaSectoresOrigen" class="list-group mt-2"></div>

                        <input type="hidden" asp-for="TbRecSecOriId" id="TbRecSecOriId" />
                    </div>
                </div>

                <div class="rec-screen-kv">
                    <div class="rec-screen-k">Sector Destino</div>

                    <div class="rec-screen-v" style="flex-direction: column; align-items: stretch;">
                        <input type="text"
                               id="TbRecSecDesBusqueda"
                               class="form-control"
                               autocomplete="off"
                               value="@(listaSectores?.FirstOrDefault(x => x.IbSecId == Model?.TbRecSecDesId)?.IbSecDen ?? "")" />

                        <div id="listaSectoresDestino" class="list-group mt-2"></div>

                        <input type="hidden" asp-for="TbRecSecDesId" id="TbRecSecDesId" />
                    </div>
                </div>

                <div class="rec-screen-kv">
                    <div class="rec-screen-k">Total recibido</div>
                    <div class="rec-screen-v">
                        <input type="text"
                               id="TbRecCantTot"
                               class="form-control form-control-sm"
                               value="@totalRecibido"
                               readonly />
                    </div>
                </div>
            </div>

            <div class="rec-screen-image" style="display:flex; align-items:center; justify-content:center;">
    
                <div id="productoImagenContainer" style="text-align:center;">
                    <div style="color:#999; font-size:0.8rem;">
                        Sin imagen
                    </div>
                </div>

            </div>
        </div>

        <div class="rec-screen-actions mt-3">
            <button type="submit" class="btn btn-primary btn-sm">Guardar Recepción</button>
        </div>
    </form>
</div>
<div class="mt-4">

    @if (Model == null || Model.TbRecId <= 0)
    {
        <div class="rec-screen-table-wrap">
            <div class="rec-screen-table-title">Carga de material</div>
            <form id="formCargaMaterial" asp-action="AgregarMaterialSimple" asp-controller="Recepcion" method="post" class="p-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="tbRecId" value="@(Model != null && Model.TbRecId > 0 ? Model.TbRecId : 0)" />

                <div class="alert alert-info py-2 mb-2" role="alert">
                    Seleccione sector de entrega para generar el numero de recepcion y habilitar la carga de material.
                </div>

                <table class="rec-screen-table rec-screen-table-entry mb-3">
                    <thead>
                        <tr>
                            <th>Codigo de Producto</th>
                            <th>Denominacion</th>
                            <th>Codigo reuso</th>
                            <th>Revision</th>
                            <th>Tarea a realizar</th>
                            <th>Contenido</th>
                            <th>Cantidad</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>
                                <select id="ibMatId" name="ibMatId" class="form-select form-select-sm" @((Model != null && Model.TbRecId > 0) ? "required" : "disabled")>
                                    <option value="">-- Seleccione --</option>
                                </select>
                            </td>
                            <td>
                                <input type="text" id="matDenominacion" class="form-control form-control-sm" readonly placeholder="Denominacion" />
                            </td>
                            <td>
                                <input type="text" id="codigoReuso" class="form-control form-control-sm" placeholder="Codigo reuso" @((Model != null && Model.TbRecId > 0) ? "" : "disabled") />
                            </td>
                            <td>
                                <select id="revisionMaterial" class="form-select form-select-sm" @((Model != null && Model.TbRecId > 0) ? "" : "disabled")>
                                    <option value="">-- Seleccione --</option>
                                    <option value="OK">OK</option>
                                    <option value="Pendiente">Pendiente</option>
                                </select>
                            </td>
                            <td>
                                <select id="tareaMaterial" class="form-select form-select-sm" @((Model != null && Model.TbRecId > 0) ? "" : "disabled")>
                                    <option value="">-- Seleccione --</option>
                                    <option value="Lavado">Lavado</option>
                                    <option value="Proceso">Proceso</option>
                                    <option value="Entrega">Entrega</option>
                                </select>
                            </td>
                            <td>
                                <input type="number" id="contenidoMaterial" class="form-control form-control-sm" min="0" step="1" placeholder="Numerico" @((Model != null && Model.TbRecId > 0) ? "" : "disabled") />
                            </td>
                            <td>
                                <input type="number" id="cantidadMaterial" name="cantidad" min="1" step="1" class="form-control form-control-sm" placeholder="Numerico" @((Model != null && Model.TbRecId > 0) ? "required" : "disabled") />
                            </td>
                        </tr>
                    </tbody>
                </table>
            </form>
        </div>
    }

    @{
        var detalles = ViewBag.Detalles as List<TbRecDetDto> ?? new List<TbRecDetDto>();
    }

    @if (detalles.Count > 0)
    {
        <div class="rec-screen-table-wrap mt-3">
            <div class="rec-screen-table-title">Materiales ingresados</div>
            <table class="rec-screen-table">
                <thead>
                    <tr>
                        <th>Codigo etiqueta</th>
                        <th>Denominacion</th>
                        <th>Codigo reuso</th>
                        <th>Recibidos</th>
                        <th>Pendientes</th>
                        <th>Entregados</th>
                        <th>Cantidad</th>
                        <th style="width:72px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in detalles)
                    {
                        <tr id="fila-det-@item.TB_REC_DET_ID">
                            <td>@item.TB_REC_DET_ID</td>
                            <td>@(string.IsNullOrWhiteSpace(item.TbRecDetMatDen) ? "SIN MATERIAL" : item.TbRecDetMatDen)</td>
                            <td>-</td>
                            <td>@item.TB_REC_DET_CANT</td>
                            <td>0</td>
                            <td>0</td>
                            <td>@item.TB_REC_DET_CANT</td>
                            <td style="white-space:nowrap;">
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger p-1 lh-1 ms-1"
                                        title="Eliminar"
                                        onclick="confirmarEliminarDetalle(@item.TB_REC_DET_ID, @(Model != null ? Model.TbRecId : 0))">
                                    <i class="bi bi-trash-fill" style="font-size:0.7rem;"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <form id="formEliminarDetalle" asp-action="EliminarDetalleMaterial" asp-controller="Recepcion" method="post" style="display:none;">
        @Html.AntiForgeryToken()
        <input type="hidden" id="elimDetId" name="tbRecDetId" />
        <input type="hidden" name="tbRecId" value="@(Model != null && Model.TbRecId > 0 ? Model.TbRecId : 0)" />
    </form>

    

    @* Botones viejos removidos. Se usan los botones del footer desde _BotonesInfoBasica.cshtml *@
    @* <div class="rec-screen-actions rec-screen-actions-bottom mt-3">
        <button type="button" class="btn btn-secondary btn-sm" onclick="window.history.back()">Cerrar</button>

        <button type="button"
                class="btn btn-outline-danger btn-sm"
                onclick="descargarRecepcionPdf(@(Model?.TbRecId ?? 0))"
