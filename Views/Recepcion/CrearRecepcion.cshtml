@model ConexionSql.Models.Recepciones.TbRec
@using ConexionSql.Models.IbPer
@using ConexionSql.Models.Sectores
@using ConexionSql.Models.Recepciones

@{
    ViewData["Title"] = "Nueva Recepción";
    var listaSectores = ViewBag.ListaSectores as List<IbSec>;

    var subFormModel = ViewBag.SubFormularioDetalle as TbRecDetFormDto;
}

<h2>Nueva Recepción</h2>

<form asp-action="CrearRecepcion" method="post">
    @Html.AntiForgeryToken()

    <div class="form-fila">
        <!-- 👤 Usuario logueado -->
        <div class="combo-form">
            <label>Usuario:</label>
            <input type="text" class="form-control" value="@ViewBag.UsuarioLogueado" readonly />
        </div>

        <!-- 🏭 Sector Origen / Destino -->
        <div class="combo-form" style="margin-left: auto;">
            <label for="TbRecSecOriId">Sector Origen:</label>
            <select asp-for="TbRecSecOriId" class="form-control mb-2">
                <option value="">-- Seleccione --</option>
                @if (listaSectores != null)
                {
                    @foreach (var s in listaSectores)
                    {
                        <option value="@s.IbSecId">@s.IbSecDen</option>
                    }
                }
            </select>

            <label for="TbRecSecDesId">Sector Destino:</label>
            <select asp-for="TbRecSecDesId" class="form-control">
                <option value="">-- Seleccione --</option>
                @if (listaSectores != null)
                {
                    @foreach (var s in listaSectores)
                    {
                        <option value="@s.IbSecId">@s.IbSecDen</option>
                    }
                }
            </select>
        </div>
    </div>

    <button type="submit" class="btn btn-primary mt-4">Guardar Recepción</button>
</form>

@if (Model != null && Model.TbRecId > 0 && subFormModel != null)
{
    subFormModel.Detalle ??= new TbRecDetDto();
    subFormModel.Detalle.TB_REC_ID = Model.TbRecId;

    <div class="mt-4">
        <h4>Agregar Material</h4>
        @await Html.PartialAsync("_SubFormRecDet", subFormModel)
    </div>
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const sectorDestino = document.getElementById("TbRecSecDesId");

            if (sectorDestino) {
                sectorDestino.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") {
                        e.preventDefault();
                        this.form.submit();
                    }
                });

                sectorDestino.addEventListener("blur", function () {
                    if (this.value) {
                        this.form.submit();
                    }
                });
            }
        });
    </script>
}