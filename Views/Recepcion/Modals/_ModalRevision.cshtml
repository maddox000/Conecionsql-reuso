<div class="modal fade" id="modalRevision" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Registro de Revisión</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="mb-3">
                    <label for="modalCantidad" class="form-label">Cantidad</label>
                    <input type="number" id="modalCantidad" class="form-control" min="1" />
                </div>

                <div class="mb-3" id="grupoFaltantes" style="display:none;">
                    <label for="modalFaltantes" class="form-label">Faltantes</label>
                    <input type="text" id="modalFaltantes" class="form-control" />
                </div>

                <div id="mensajeModalRevision" class="text-danger"></div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnAceptarModal" class="btn btn-primary">Aceptar</button>
            </div>

        </div>
    </div>
</div>