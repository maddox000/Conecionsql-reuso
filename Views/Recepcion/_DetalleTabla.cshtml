@model List<ConexionSql.Models.Recepciones.TbRecDetDto>

<div class="rec-screen-table-wrap mt-3">
    <div class="rec-screen-table-title">Materiales ingresados</div>

    <table class="rec-screen-table">
        <thead>
            <tr>
                <th>Codigo etiqueta</th>
                <th>Denominacion</th>
                <th>Estado</th>
                <th>Cantidad</th>
                <th style="width:72px;"></th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Count > 0)
            {
                foreach (var item in Model)
                {
                    <tr id="fila-det-@item.TB_REC_DET_ID">
                        <td>@item.TB_REC_DET_ID</td>
                        <td>@item.TbRecDetMatDen</td>
                        <td>@item.IB_EST_DEN</td>
                        <td>@item.TB_REC_DET_CANT</td>
                        <td style="white-space:nowrap;">
                            <button type="button"
                                    class="btn btn-sm btn-outline-danger p-1 lh-1 ms-1"
                                    title="Eliminar"
                                    onclick="confirmarEliminarDetalle(@item.TB_REC_DET_ID, 0)">
                                <i class="bi bi-trash-fill" style="font-size:0.7rem;"></i>
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center text-muted">
                        No hay detalles cargados.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>