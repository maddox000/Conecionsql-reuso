@model List<ConexionSql.Models.Entrega.TbEntDetDto>

<!-- _DetalleTabla -->
<!-- Tabla que muestra los detalles de la entrega -->
<table class="table table-bordered table-sm">
    <thead class="thead-dark">
        <tr>
            <th style="width: 20%;">Código Material</th>
            <th style="width: 50%;">Denominación</th>
            <th style="width: 15%;">Cantidad</th>
            <th style="width: 15%;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Count > 0)
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.IB_MAT_ID</td>
                    <td>@item.TbEntDetRecDetMatDen</td>
                    <td>@item.TB_ENT_DET_CANT</td>
                    <td>
                        <!-- Botón de eliminar usando ID real del detalle -->
                        <button type="button" class="btn btn-danger btn-sm" onclick="eliminarDetalle(@item.TB_ENT_DET_ID)">
                            Eliminar
                        </button>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="4" class="text-center text-muted">No hay detalles cargados.</td>
            </tr>
        }
    </tbody>
</table>
