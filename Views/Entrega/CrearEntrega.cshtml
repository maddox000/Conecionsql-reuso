@model ConexionSql.Models.Entrega.TbEntFormDto
@using ConexionSql.Models.IbPer
@using ConexionSql.Models.Sectores
@using ConexionSql.Models.Entrega




@{
    ViewData["Title"] = "Crear Entrega";
    var listaPersonal = ViewBag.ListaPersonal as List<IbPerDto>;
    var listaSectores = ViewBag.ListaSectores as List<IbSec>;

    var usuarioId = ViewBag.UsuarioId;
    var usuarioLogueado = ViewBag.UsuarioLogueado as string;
}

<link rel="stylesheet" href="~/css/views/crear-entrega.css" asp-append-version="true" />

<div class="bx-card entrega-demo">
    <div class="entrega-banner">Entrega de materiales</div>

    <form id="formCrearEntrega" onsubmit="return false;">
        <div class="entrega-grid">

            <div class="entrega-panel">
                <div class="entrega-kv">
                    <div class="k">Numero de entrega</div>
                    <div class="v">-</div>
                </div>

                <div class="entrega-kv">
                    <div class="k">Usuario</div>
                    <div class="v">
                        <input type="text"
                               class="form-control form-control-sm"
                               id="usuarioLogueado"
                               value="@usuarioLogueado"
                               readonly />
                    </div>
                </div>

                <div class="entrega-kv">
                    <div class="k">Cargo</div>
                    <div class="v">-</div>
                </div>

                <div class="entrega-kv entrega-kv-total">
                    <div class="k">Total entregado</div>
                    <div class="v">0 Unidades</div>
                </div>

                <div class="entrega-checks compact">
                    <label class="entrega-check"><input type="checkbox" /><span class="entrega-check-number">1.</span> Integridad envoltorios</label>
                    <label class="entrega-check"><input type="checkbox" /><span class="entrega-check-number">2.</span> Ausencia de suciedad</label>
                    <label class="entrega-check"><input type="checkbox" /><span class="entrega-check-number">3.</span> Control quimico virado</label>
                    <label class="entrega-check"><input type="checkbox" /><span class="entrega-check-number">4.</span> Ausencia de humedad</label>
                    <label class="entrega-check"><input type="checkbox" /><span class="entrega-check-number">5.</span> Envoltorios correctos</label>
                </div>
            </div>

            <div class="entrega-panel">
                <div class="entrega-kv">
                    <div class="k">Fecha</div>
                    <div class="v">
                        <input type="text"
                               class="form-control form-control-sm"
                               id="fechaEntrega"
                               value="@DateTime.Today.ToString("yyyy-MM-dd")"
                               readonly />
                    </div>
                </div>

                <div class="entrega-kv">
                    <div class="k">Hora</div>
                    <div class="v">
                        <input type="text"
                               class="form-control form-control-sm"
                               id="horaInicio"
                               value="@DateTime.Now.ToString("HH:mm")"
                               readonly />
                    </div>
                </div>

                <div class="entrega-kv">
                    <div class="k">Sector de entrega</div>
                    <div class="v">
                        <input type="text"
                               class="form-control form-control-sm"
                               id="TB_ENT_SEC_BUSQUEDA"
                               autocomplete="off"
                               placeholder="Buscar sector..." />

                        <div id="listaSectores" class="list-group mt-2"></div>

                        <input type="hidden" id="TB_ENT_SEC_ID" />
                    </div>
                </div>

                <div class="entrega-kv">
                    <div class="k">Personal del sector</div>
                    <div class="v">
                        <input type="text"
                               class="form-control form-control-sm"
                               id="TB_ENT_SEC_PER"
                               placeholder="Ingrese personal del sector" />
                    </div>
                </div>

                <div class="entrega-kv">
                    <div class="k">Horario conformidad</div>
                    <div class="v">--:--</div>
                </div>
            </div>
        </div>

        <textarea class="entrega-observ"
                  id="TB_ENT_OBS"
                  rows="3"
                  placeholder="Ingrese observaciones"></textarea>

        <div class="entrega-actions d-flex gap-2 align-items-center justify-content-end">
            <button type="button" class="btn btn-primary" onclick="guardarEntrega()">
                Guardar Entrega
            </button>

            <button type="button" class="btn btn-primary" onclick="window.history.back()">
                Cerrar
            </button>
        </div>

        <div id="mensajeEntrega" class="mt-3 text-danger"></div>
    </form>
</div>

@section Scripts {
    <script>
        async function guardarEntrega() {
            const fecha = document.getElementById("fechaEntrega").value;
            const horaIni = document.getElementById("horaInicio").value;
            const perId = @((usuarioId ?? 0));
            const perNom = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(usuarioLogueado ?? ""));
            const secId = document.getElementById("TB_ENT_SEC_ID").value;
            const secDen = document.getElementById("TB_ENT_SEC_BUSQUEDA").value || "";
            const secPer = document.getElementById("TB_ENT_SEC_PER").value || "";
            const obs = document.getElementById("TB_ENT_OBS").value || "";

            if (!perId || perId === 0) {
                document.getElementById("mensajeEntrega").innerText = "❌ No hay usuario logueado en sesión.";
                return;
            }

            if (!secId) {
                document.getElementById("mensajeEntrega").innerText = "⚠️ Debe seleccionar sector.";
                return;
            }

            const data = {
                TB_ENT_FEC: fecha,
                TB_ENT_HOR_INI: horaIni,
                TB_ENT_HOR_FIN: null,
                TB_ENT_PER_ID: parseInt(perId),
                TB_ENT_PER_NOM: perNom,
                TB_ENT_SEC_ID: parseInt(secId),
                TB_ENT_SEC_DEN: secDen,
                TB_ENT_SEC_PER: secPer,
                TB_ENT_OBS: obs,
                TB_ENT_CANT_TOT: 0
            };

            const resp = await fetch('/Entrega/Insertar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const json = await resp.json();

            if (json.success) {
                window.location.href = `/TbEntDet/SubFormulario/${json.tbEntId}`;
            } else {
                document.getElementById("mensajeEntrega").innerText =
                    json.mensaje || "❌ Error al guardar la entrega.";
            }
        }
    </script>

    <script>
        localStorage.setItem("modulo_25_abierto", "1");

        window.addEventListener("beforeunload", function () {
            localStorage.removeItem("modulo_25_abierto");
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const sector = document.getElementById("TB_ENT_SEC_BUSQUEDA");

            if (sector) {
                setTimeout(() => {
                    sector.focus();
                }, 200);
            }
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const input = document.getElementById("TB_ENT_SEC_BUSQUEDA");
            const lista = document.getElementById("listaSectores");
            const hidden = document.getElementById("TB_ENT_SEC_ID");
            const inputPersonal = document.getElementById("TB_ENT_SEC_PER");
            const inputObs = document.getElementById("TB_ENT_OBS");

            let indice = -1;
            let itemsFiltrados = [];

            if (!input) return;

            const sectores = [
                @if (listaSectores != null)
                {
                        for (int i = 0; i < listaSectores.Count; i++)
                        {
                                var s = listaSectores[i];
                                @:{ id: @s.IbSecId, den: "@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(s.IbSecDen ?? ""))" }@(i < listaSectores.Count - 1 ? "," : "")
                        }
                }
            ];

            function marcarActivo() {
                const items = lista.querySelectorAll(".list-group-item");

                items.forEach((el, i) => {
                    el.classList.toggle("active", i === indice);
                });
            }

            function seleccionarSector(sec) {
                input.value = sec.den;
                hidden.value = sec.id;
                lista.innerHTML = "";
                indice = -1;

                if (inputPersonal) {
                    inputPersonal.focus();
                    inputPersonal.select();
                }
            }

            input.addEventListener("input", function () {
                const texto = this.value.toLowerCase().trim();

                lista.innerHTML = "";
                hidden.value = "";
                indice = -1;

                if (texto.length < 1) {
                    itemsFiltrados = [];
                    return;
                }

                itemsFiltrados = sectores.filter(s =>
                    s.den.toLowerCase().includes(texto)
                );

                itemsFiltrados.forEach(sec => {
                    const item = document.createElement("a");
                    item.classList.add("list-group-item", "list-group-item-action");
                    item.textContent = sec.den;
                    item.href = "#";

                    item.addEventListener("click", function (e) {
                        e.preventDefault();
                        seleccionarSector(sec);
                    });

                    lista.appendChild(item);
                });
            });

            input.addEventListener("keydown", function (e) {

                if (e.key === "ArrowDown") {
                    if (!itemsFiltrados.length) return;
                    e.preventDefault();
                    indice = (indice + 1) % itemsFiltrados.length;
                    marcarActivo();
                }

                if (e.key === "ArrowUp") {
                    if (!itemsFiltrados.length) return;
                    e.preventDefault();
                    indice = (indice - 1 + itemsFiltrados.length) % itemsFiltrados.length;
                    marcarActivo();
                }

                if (e.key === "Enter") {
                    e.preventDefault();

                    if (indice >= 0 && itemsFiltrados[indice]) {
                        seleccionarSector(itemsFiltrados[indice]);
                        return;
                    }

                    const texto = input.value.trim().toLowerCase();
                    const exacto = sectores.find(s => s.den.toLowerCase() === texto);

                    if (exacto) {
                        seleccionarSector(exacto);
                    } else if (inputPersonal) {
                        inputPersonal.focus();
                        inputPersonal.select();
                    }
                }
            });

            if (inputPersonal) {
                inputPersonal.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") {
                        e.preventDefault();
                        if (inputObs) {
                            inputObs.focus();
                        }
                    }
                });
            }

            if (inputObs) {
                inputObs.addEventListener("keydown", function (e) {
                    if (e.key === "Enter" && !e.shiftKey) {
                        e.preventDefault();
                        guardarEntrega();
                    }
                });
            }

            document.addEventListener("click", function (e) {
                if (!input.contains(e.target) && !lista.contains(e.target)) {
                    lista.innerHTML = "";
                }
            });

        });
    </script>
}
}