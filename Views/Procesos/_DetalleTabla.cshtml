@model List<ConexionSql.Models.Procesos.TbProDetDto>

<table class="proceso-table">
    <thead>
        <tr>
            <th>Codigo etiqueta</th>
            <th>Denominacion</th>
            <th>Sector</th>
            <th>Codigo reuso</th>
            <th>Recibidos</th>
            <th>En proceso</th>
            <th>Sin procesar</th>
            <th>Cantidad</th>
            <th>Imprimir</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.TB_PRO_DET_REC_DET_ID</td>
                    <td>@item.TB_PRO_DET_REC_DET_MAT_DEN</td>
                    <td>-</td>
                    <td>-</td>
                    <td>-</td>
                    <td>-</td>
                    <td>-</td>
                    <td>@item.TB_PRO_DET_CANT</td>
                    <td>
                        <div class="proceso-print-actions" role="group" aria-label="Acciones de impresion por etiqueta">
                            <button type="button"
                                    class="btn btn-outline-primary proceso-row-icon-btn js-pro-row-print-pdf"
                                    data-etiqueta="@item.TB_PRO_DET_REC_DET_ID"
                                    title="Imprimir etiqueta @item.TB_PRO_DET_REC_DET_ID en PDF"
                                    aria-label="Imprimir etiqueta @item.TB_PRO_DET_REC_DET_ID en PDF">
                                <i class="bi bi-file-earmark-pdf-fill"></i>
                            </button>

                            <button type="button"
                                    class="btn btn-outline-primary proceso-row-icon-btn js-pro-row-print-printer"
                                    data-etiqueta="@item.TB_PRO_DET_REC_DET_ID"
                                    title="Opciones de impresora para @item.TB_PRO_DET_REC_DET_ID"
                                    aria-label="Opciones de impresora para @item.TB_PRO_DET_REC_DET_ID">
                                <i class="bi bi-printer-fill"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="9" class="proceso-table-empty-note">Sin materiales cargados</td>
            </tr>
        }
    </tbody>
</table>