@model ConexionSql.Models.Procesos.TbProFormDto

@{
    ViewData["Title"] = "Crear Proceso";
    var fechaHoy = DateTime.Now.ToString("yyyy-MM-dd");
    var horaInicio = DateTime.Now.ToString("HH:mm");
}

<link rel="stylesheet" href="~/css/views/crear-procesos.css" asp-append-version="true" />

<div class="bx-card proceso-demo">
    <div class="proceso-banner">Proceso de Esterilizacion</div>

    <div class="proceso-operativo">
        <form id="formCrearProceso" onsubmit="return false;">
            <div class="proceso-operativo-grid">
                <div class="bx-form-group">
                    <label for="fechaProceso">Fecha</label>
                    <input type="text" class="form-control form-control-sm" id="fechaProceso" value="@fechaHoy" readonly />
                </div>

                <div class="bx-form-group">
                    <label for="horaInicio">Hora Inicio</label>
                    <input type="text" class="form-control form-control-sm" id="horaInicio" value="@horaInicio" readonly />
                </div>

                <div class="bx-form-group">
                    <label for="TipoProcesoId">Tipo de Proceso</label>
                    <select class="form-select form-select-sm" asp-for="TipoProcesoId" asp-items="Model.TiposProceso" id="TipoProcesoId" required>
                        <option value="">-- Seleccionar tipo --</option>
                    </select>
                </div>

                <div class="bx-form-group">
                    <label for="EquipoId">Equipo</label>
                    <select class="form-select form-select-sm" asp-for="EquipoId" asp-items="Model.Equipos" id="EquipoId" required>
                        <option value="">-- Seleccionar equipo --</option>
                    </select>
                </div>

                <div class="bx-form-group">
                    <label for="TipoCicloId">Tipo de Ciclo</label>
                    <select class="form-select form-select-sm" asp-for="TipoCicloId" asp-items="Model.TiposCiclo" id="TipoCicloId" required>
                        <option value="">-- Seleccionar ciclo --</option>
                    </select>
                </div>

                <div class="bx-form-group" id="grupoProveedor" style="display:none;">
                    <label for="ProveedorId">Proveedor</label>
                    <select class="form-select form-select-sm" id="ProveedorId">
                        <option value="">-- Seleccionar proveedor --</option>
                    </select>
                </div>
            </div>

            <div class="proceso-operativo-actions mt-2">
                <button type="button" class="btn btn-primary btn-sm" onclick="guardarProceso()">Guardar Proceso</button>
            </div>

            <div id="mensajeProceso"></div>
        </form>
    </div>

    <div class="proceso-grid">
        <div class="proceso-panel">
            <div class="proceso-kv">
                <div class="k">Numero de proceso</div>
                <div class="v" id="panelNumeroProceso">0</div>
            </div>

            <div class="proceso-kv">
                <div class="k">Usuario</div>
                <div class="v" id="panelUsuario">-</div>
            </div>

            <div class="proceso-kv">
                <div class="k">Cargo</div>
                <div class="v" id="panelCargo">-</div>
            </div>

            <div class="proceso-title">Datos del proceso</div>

            <div class="proceso-kv">
                <div class="k">Tipo de proceso</div>
                <div class="v" id="panelTipoProceso">-</div>
            </div>

            <div class="proceso-kv">
                <div class="k">Estado del ciclo</div>
                <div class="v" id="panelEstadoCiclo">EN PROCESO</div>
            </div>

            <div class="proceso-kv">
                <div class="k">Tipo de ciclo</div>
                <div class="v" id="panelTipoCiclo">-</div>
            </div>

            <div class="proceso-kv">
                <div class="k">Numero de proceso</div>
                <div class="v" id="panelNumeroInterno">0</div>
            </div>

            <div class="proceso-kv">
                <div class="k">Unidades procesadas</div>
                <div class="v" id="panelUnidadesProcesadas">0</div>
            </div>

            <div class="proceso-kv">
                <div class="k">Volumen procesado</div>
                <div class="v" id="panelVolumenProcesado">0</div>
            </div>
        </div>

        <div class="proceso-panel">
            <div class="proceso-kv">
                <div class="k">Fecha</div>
                <div class="v" id="panelFechaCompleta">@DateTime.Now.ToString("dd/MM/yyyy") @horaInicio</div>
            </div>

            <div class="proceso-title proceso-title-offset">Datos del equipo</div>

            <div class="proceso-kv">
                <div class="k">Marca</div>
                <div class="v" id="panelMarcaEquipo">-</div>
            </div>

            <div class="proceso-kv">
                <div class="k">Numero de serie</div>
                <div class="v" id="panelSerieEquipo">-</div>
            </div>

            <div class="proceso-kv">
                <div class="k">Modelo</div>
                <div class="v" id="panelModeloEquipo">-</div>
            </div>

            <div class="proceso-kv">
                <div class="k">Numero de equipo</div>
                <div class="v" id="panelNumeroEquipo">-</div>
            </div>
        </div>
    </div>

    <div class="proceso-observ">
        <div class="k proceso-observ-label">Observaciones</div>
        <textarea id="panelObservaciones" readonly>NO REGISTRA</textarea>
    </div>

    <div class="proceso-tabs" role="tablist" aria-label="Secciones del proceso">
        <button type="button" class="proceso-tab is-active" data-tab-target="proceso-tab-materiales">Materiales procesados</button>
        <button type="button" class="proceso-tab" data-tab-target="proceso-tab-cancelados">Materiales cancelados</button>
        <button type="button" class="proceso-tab" data-tab-target="proceso-tab-controles">Controles de proceso</button>
    </div>

    <div id="proceso-tab-materiales" class="proceso-tab-panel is-active">
        <div class="proceso-materiales-wrap">
            <table class="proceso-table">
                <thead>
                    <tr>
                        <th>Codigo etiqueta</th>
                        <th>Denominacion</th>
                        <th>Sector</th>
                        <th>Codigo reuso</th>
                        <th>Recibidos</th>
                        <th>En proceso</th>
                        <th>Sin procesar</th>
                        <th>Cantidad</th>
                        <th>Imprimir</th>
                    </tr>
                </thead>
                <tbody id="tablaMaterialesProcesados">
                    <tr>
                        <td colspan="9" class="proceso-table-empty-note">Sin materiales cargados</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div id="proceso-tab-cancelados" class="proceso-tab-panel">
        <div class="proceso-materiales-wrap">
            <table class="proceso-table">
                <thead>
                    <tr>
                        <th>Codigo etiqueta</th>
                        <th>Denominacion</th>
                        <th>Sector</th>
                        <th>Codigo reuso</th>
                        <th>Recibidos</th>
                        <th>En proceso</th>
                        <th>Sin procesar</th>
                        <th>Cantidad</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="8" class="proceso-table-empty-note">Sin materiales cancelados</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div id="proceso-tab-controles" class="proceso-tab-panel">
        <div class="proceso-work">
            <div>
                <table class="proceso-mini-table">
                    <thead>
                        <tr>
                            <th>Tipo de control</th>
                            <th>Identificacion</th>
                            <th>Ubicacion</th>
                            <th>Cantidad</th>
                        </tr>
                    </thead>
                    <tbody id="tablaControlesProceso">
                        <tr>
                            <td colspan="4" class="proceso-table-empty-note">Sin controles cargados</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="proceso-diagram" aria-label="Mapa de camara">
                <svg viewBox="0 0 290 110" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <line x1="50" y1="13" x2="210" y2="13" stroke="#b8c0ca" stroke-width="2" />
                    <line x1="50" y1="13" x2="50" y2="66" stroke="#b8c0ca" stroke-width="2" />
                    <line x1="210" y1="13" x2="210" y2="66" stroke="#b8c0ca" stroke-width="2" />
                    <line x1="50" y1="66" x2="210" y2="66" stroke="#b8c0ca" stroke-width="2" />
                    <line x1="82" y1="34" x2="242" y2="34" stroke="#b8c0ca" stroke-width="2" />
                    <line x1="82" y1="34" x2="82" y2="94" stroke="#b8c0ca" stroke-width="2" />
                    <line x1="242" y1="34" x2="242" y2="94" stroke="#b8c0ca" stroke-width="2" />
                    <line x1="82" y1="94" x2="242" y2="94" stroke="#b8c0ca" stroke-width="2" />
                    <line x1="50" y1="13" x2="82" y2="34" stroke="#b8c0ca" stroke-width="2" />
                    <line x1="210" y1="13" x2="242" y2="34" stroke="#b8c0ca" stroke-width="2" />
                    <line x1="50" y1="66" x2="82" y2="94" stroke="#b8c0ca" stroke-width="2" />
                    <line x1="210" y1="66" x2="242" y2="94" stroke="#b8c0ca" stroke-width="2" />
                </svg>

                <div class="node proceso-node-1">1</div>
                <div class="node proceso-node-2">2</div>
                <div class="node proceso-node-3">3</div>
                <div class="node proceso-node-4">4</div>
                <div class="node proceso-node-5">5</div>
                <div class="node proceso-node-6">6</div>
                <div class="node proceso-node-7">7</div>
                <div class="node proceso-node-8">8</div>
                <div class="node proceso-node-9">9</div>
                <div class="proceso-bd">BD</div>
                <div class="proceso-door-label proceso-door-label-left">Puerta de carga</div>
                <div class="proceso-door-label proceso-door-label-right">Puerta de descarga</div>
            </div>
        </div>
    </div>

    <div class="proceso-table-wrap">
        <table class="proceso-table">
            <thead>
                <tr>
                    <th>Codigo etiqueta</th>
                    <th>Denominacion</th>
                    <th>Sector</th>
                    <th>Codigo reuso</th>
                    <th>Recibidos</th>
                    <th>En proceso</th>
                    <th>Sin procesar</th>
                    <th>Cantidad</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td colspan="7"></td>
                    <td id="panelTotalTablaInferior">0</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="proceso-actions">
        <button type="button" class="btn btn-primary" onclick="guardarProceso()">Nuevo</button>
        <button type="button" class="btn btn-outline-primary" onclick="alert('Accion de demostracion')">Controles de proceso</button>
        <button type="button" class="btn btn-outline-primary" onclick="alert('Accion de demostracion')">Editar</button>
        <button type="button" class="btn btn-secondary" onclick="window.history.back()">Cerrar</button>
    </div>
</div>

<div id="contenedorSubform" class="mt-5"></div>

<div class="modal fade" id="procesoPrinterTypeModal" tabindex="-1" aria-labelledby="procesoPrinterTypeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-primary" style="max-width:420px;">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="procesoPrinterTypeModalLabel">Seleccione el tipo de impresión</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p id="procesoPrinterRowInfo" class="mb-2 small text-muted">Etiqueta seleccionada: -</p>
                <div class="d-flex gap-2 justify-content-end">
                    <button type="button" class="btn btn-primary" id="btnProcesoPrintDocument">Impresora</button>
                    <button type="button" class="btn btn-outline-primary" id="btnProcesoPrintLabel">Etiqueta</button>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        async function cargarTiposCiclo(ptiId, comboCiclo) {
            comboCiclo.innerHTML = '<option value="">-- Cargando ciclos... --</option>';

            try {
                const resp = await fetch(`/Proceso/ObtenerTiposCicloPorProceso?ptiId=${ptiId}`);
                const ciclos = await resp.json();

                comboCiclo.innerHTML = '<option value="">-- Seleccionar ciclo --</option>';

                if (Array.isArray(ciclos) && ciclos.length > 0) {
                    ciclos.forEach(c => {
                        const opt = document.createElement("option");
                        opt.value = c.id;
                        opt.text = c.nombre;
                        comboCiclo.appendChild(opt);
                    });
                } else {
                    comboCiclo.innerHTML = '<option value="">-- Sin ciclos disponibles --</option>';
                }
            } catch (error) {
                console.error("Error cargando ciclos:", error);
                comboCiclo.innerHTML = '<option value="">-- Error al cargar ciclos --</option>';
            }
        }

        async function cargarEquipos(ptiId, comboEquipo) {
            comboEquipo.innerHTML = '<option value="">-- Cargando equipos... --</option>';

            try {
                const resp = await fetch(`/Proceso/ObtenerEquiposPorTipo?ptiId=${ptiId}`);
                const equipos = await resp.json();

                comboEquipo.innerHTML = '<option value="">-- Seleccionar equipo --</option>';

                if (Array.isArray(equipos) && equipos.length > 0) {
                    equipos.forEach(e => {
                        const opt = document.createElement("option");
                        opt.value = e.id;
                        opt.text = e.nombre;
                        comboEquipo.appendChild(opt);
                    });
                } else {
                    comboEquipo.innerHTML = '<option value="">-- Sin equipos disponibles --</option>';
                }
            } catch (error) {
                console.error("Error cargando equipos:", error);
                comboEquipo.innerHTML = '<option value="">-- Error al cargar equipos --</option>';
            }
        }

        async function cargarProveedores(comboProveedor) {
            comboProveedor.innerHTML = '<option value="">-- Cargando proveedores... --</option>';

            try {
                const resp = await fetch('/Proceso/ObtenerProveedores');
                const proveedores = await resp.json();

                comboProveedor.innerHTML = '<option value="">-- Seleccionar proveedor --</option>';

                if (Array.isArray(proveedores) && proveedores.length > 0) {
                    proveedores.forEach(p => {
                        const opt = document.createElement("option");
                        opt.value = p.id;
                        opt.text = p.nombre;
                        comboProveedor.appendChild(opt);
                    });
                } else {
                    comboProveedor.innerHTML = '<option value="">-- Sin proveedores disponibles --</option>';
                }
            } catch (error) {
                console.error("Error cargando proveedores:", error);
                comboProveedor.innerHTML = '<option value="">-- Error al cargar proveedores --</option>';
            }
        }

        async function guardarProceso() {
            const mensaje = document.getElementById("mensajeProceso");
            if (mensaje) mensaje.innerText = "";

            const tipoProcesoSelect = document.getElementById("TipoProcesoId");
            const equipoSelect = document.getElementById("EquipoId");
            const tipoCicloSelect = document.getElementById("TipoCicloId");
            const proveedorSelect = document.getElementById("ProveedorId");

            const tipoProcesoId = parseInt(tipoProcesoSelect?.value || "") || 0;
            const esExterno = tipoProcesoId === 5;

            const equipoIdLeido = parseInt(equipoSelect?.value || "") || 0;
            const tipoCicloIdLeido = parseInt(tipoCicloSelect?.value || "") || 0;
            const proveedorIdLeido = parseInt(proveedorSelect?.value || "") || 0;

            if (!tipoProcesoId) {
                mensaje.innerText = "⚠️ Complete el tipo de proceso.";
                return;
            }

            if (esExterno) {
                if (!proveedorIdLeido) {
                    mensaje.innerText = "⚠️ Debe seleccionar un proveedor.";
                    return;
                }
            } else {
                if (!equipoIdLeido || equipoIdLeido <= 0) {
                    mensaje.innerText = "⚠️ Debe seleccionar un equipo válido.";
                    return;
                }

                if (!tipoCicloIdLeido || tipoCicloIdLeido <= 0) {
                    mensaje.innerText = "⚠️ Debe seleccionar un tipo de ciclo válido.";
                    return;
                }
            }

            const data = {
                TbProFec: document.getElementById("fechaProceso")?.value,
                TbProHorIni: document.getElementById("horaInicio")?.value,

                TipoProcesoId: tipoProcesoId,
                TipoProcesoDen: tipoProcesoSelect?.selectedOptions[0]?.text || "",

                EquipoId: esExterno ? 1 : equipoIdLeido,
                EquipoDen: esExterno ? "1" : (equipoSelect?.selectedOptions[0]?.text || ""),

                TipoCicloId: esExterno ? 1 : tipoCicloIdLeido,
                TipoCicloDen: esExterno ? "1" : (tipoCicloSelect?.selectedOptions[0]?.text || ""),

                ProveedorId: esExterno ? proveedorIdLeido : null,
                ProveedorDen: esExterno ? (proveedorSelect?.selectedOptions[0]?.text || "") : "",

                UsuarioId: parseInt(localStorage.getItem("usuarioId") || "0"),
                UsuarioNom: localStorage.getItem("usuarioNom") || "",
                UsuarioApe: localStorage.getItem("usuarioApe") || "",
                UsuarioCarId: parseInt(localStorage.getItem("usuarioCarId") || "0"),
                UsuarioCarDen: localStorage.getItem("usuarioCarDen") || ""
            };

            try {
                console.log("Payload enviado:", data);
                //debugger;

                const resp = await fetch('/Proceso/Insertar', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const json = await resp.json();
                console.log("JSON recibido:", json);

                if (json.success) {
                    if (!json.redirectUrl) {
                        mensaje.innerText = "❌ No vino redirectUrl desde el controller.";
                        return;
                    }

                    window.location.href = json.redirectUrl;
                } else {
                    mensaje.innerText = json.mensaje || "❌ Error al guardar el proceso.";
                }

            } catch (error) {
                console.error("Error en guardarProceso:", error);
                mensaje.innerText = "❌ Error de conexión con el servidor.";
            }
        }

        function textoSeleccionado(selectId, fallback = "-") {
            const select = document.getElementById(selectId);
            if (!select) return fallback;
            return select.selectedOptions?.[0]?.text?.trim() || fallback;
        }

        function valorSeleccionado(selectId, fallback = "-") {
            const select = document.getElementById(selectId);
            if (!select) return fallback;
            return select.value?.trim() || fallback;
        }

        function setText(id, value) {
            const el = document.getElementById(id);
            if (el) el.textContent = value;
        }

        function limpiarNodosControl() {
            document.querySelectorAll(".proceso-diagram .node").forEach(n => {
                n.classList.remove("activo");
            });

            document.querySelector(".proceso-bd")?.classList.remove("activo");
        }




        window.marcarNodo = function (posicion) {
            document.querySelectorAll(".proceso-diagram .node")
                .forEach(n => {
                    if (n.textContent.trim() === String(posicion)) {
                        n.classList.add("activo");
                    }
                });

            if (String(posicion) === "28") {
                document.querySelector(".proceso-bd")?.classList.add("activo");
            }
        };


        function sincronizarResumenProceso() {
            const usuarioNom = localStorage.getItem("usuarioNom") || "";
            const usuarioApe = localStorage.getItem("usuarioApe") || "";
            const usuarioCarDen = localStorage.getItem("usuarioCarDen") || "-";

            const nombreCompleto = `${usuarioApe}${usuarioApe && usuarioNom ? ", " : ""}${usuarioNom}`.trim() || "-";

            setText("panelUsuario", nombreCompleto);
            setText("panelCargo", usuarioCarDen);
            setText("panelTipoProceso", textoSeleccionado("TipoProcesoId"));
            setText("panelTipoCiclo", textoSeleccionado("TipoCicloId"));
            setText("panelNumeroEquipo", valorSeleccionado("EquipoId"));
            setText("panelMarcaEquipo", textoSeleccionado("EquipoId"));
            setText("panelSerieEquipo", valorSeleccionado("EquipoId"));
            setText("panelModeloEquipo", textoSeleccionado("EquipoId"));

            const fecha = document.getElementById("fechaProceso")?.value || "";
            const hora = document.getElementById("horaInicio")?.value || "";
            setText("panelFechaCompleta", `${fecha} ${hora}`.trim());
        }

        document.addEventListener("DOMContentLoaded", function () {
            const tipoProceso = document.getElementById("TipoProcesoId");

            tipoProceso?.addEventListener("change", async function () {
                const ptiId = this.value;

                const grupoEquipo = document.getElementById("EquipoId")?.parentElement;
                const grupoCiclo = document.getElementById("TipoCicloId")?.parentElement;
                const grupoProveedor = document.getElementById("grupoProveedor");

                const comboEquipo = document.getElementById("EquipoId");
                const comboCiclo = document.getElementById("TipoCicloId");
                const comboProveedor = document.getElementById("ProveedorId");

                document.getElementById("mensajeProceso").innerText = "";

                if (comboEquipo) comboEquipo.innerHTML = '<option value="">-- Seleccionar equipo --</option>';
                if (comboCiclo) comboCiclo.innerHTML = '<option value="">-- Seleccionar ciclo --</option>';
                if (comboProveedor) comboProveedor.innerHTML = '<option value="">-- Seleccionar proveedor --</option>';

                if (!ptiId) {
                    if (grupoEquipo) grupoEquipo.style.display = "block";
                    if (grupoCiclo) grupoCiclo.style.display = "block";
                    if (grupoProveedor) grupoProveedor.style.display = "none";
                    sincronizarResumenProceso();
                    return;
                }

                if (ptiId === "5") {
                    if (grupoEquipo) grupoEquipo.style.display = "none";
                    if (grupoCiclo) grupoCiclo.style.display = "none";
                    if (grupoProveedor) grupoProveedor.style.display = "block";

                    if (comboEquipo) {
                        comboEquipo.innerHTML = '<option value="1">1</option>';
                        comboEquipo.value = "1";
                    }

                    if (comboCiclo) {
                        comboCiclo.innerHTML = '<option value="1">1</option>';
                        comboCiclo.value = "1";
                    }

                    if (comboProveedor) {
                        comboProveedor.innerHTML = '<option value="">-- Cargando proveedores... --</option>';

                        try {
                            const respProv = await fetch('/Proceso/ObtenerProveedores');
                            const proveedores = await respProv.json();

                            comboProveedor.innerHTML = '<option value="">-- Seleccionar proveedor --</option>';

                            if (Array.isArray(proveedores) && proveedores.length > 0) {
                                proveedores.forEach(p => {
                                    const opt = document.createElement("option");
                                    opt.value = p.id;
                                    opt.text = p.nombre;
                                    comboProveedor.appendChild(opt);
                                });
                            } else {
                                comboProveedor.innerHTML = '<option value="">-- Sin proveedores disponibles --</option>';
                            }
                        } catch (error) {
                            console.error("Error cargando proveedores:", error);
                            comboProveedor.innerHTML = '<option value="">-- Error al cargar proveedores --</option>';
                        }
                    }

                    sincronizarResumenProceso();
                    return;
                }

                if (grupoEquipo) grupoEquipo.style.display = "block";
                if (grupoCiclo) grupoCiclo.style.display = "block";
                if (grupoProveedor) grupoProveedor.style.display = "none";

                if (comboEquipo) await cargarEquipos(ptiId, comboEquipo);
                if (comboCiclo) await cargarTiposCiclo(ptiId, comboCiclo);

                sincronizarResumenProceso();
            });

            sincronizarResumenProceso();

            document.getElementById("EquipoId")?.addEventListener("change", sincronizarResumenProceso);
            document.getElementById("TipoCicloId")?.addEventListener("change", sincronizarResumenProceso);
            document.getElementById("ProveedorId")?.addEventListener("change", sincronizarResumenProceso);

