            });

            document.getElementById("btnProcesoPrintLabel")?.addEventListener("click", function () {
                alert("Impresion de etiqueta");
            });

            //abrirModalControlProceso modal de controles de proceso

        const nodos = document.querySelectorAll(".proceso-diagram .node");

        nodos.forEach(nodo => {
            nodo.addEventListener("dblclick", function () {
                const posicion = this.textContent.trim();
                const tbProId = parseInt(document.getElementById("panelNumeroProceso")?.textContent || "0");
                abrirModalControlProceso(tbProId, posicion);
