@model List<ConexionSql.Models.Procesos.TbProDto>
@{
    ViewData["Title"] = "Búsqueda de Procesos";
}

<h2>Búsqueda de Procesos</h2>

<form asp-action="BuscarProcesos" method="get" class="mb-4">
    <div class="form-group">
        <label for="fechaInicio">Inicio búsqueda</label>
        <input type="date" id="fechaInicio" name="fechaInicio" class="form-control"
               value="@ViewBag.FechaInicio" />
    </div>
    <div class="form-group">
        <label for="fechaFin">Final búsqueda</label>
        <input type="date" id="fechaFin" name="fechaFin" class="form-control"
               value="@ViewBag.FechaFin" />
    </div>
    <div class="form-group">
        <label for="tipoProceso">Tipo de proceso</label>
        <input type="text" id="tipoProceso" name="tipoProceso" class="form-control"
               value="@ViewBag.TipoProceso" placeholder="Ej: VAPOR" />
    </div>
    <button type="submit" class="btn btn-primary">Buscar</button>
</form>

@if (Model != null && Model.Any())
{
    <h4>Resultados</h4>
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Proceso</th>
                <th>Nro Lote</th>
                <th>Fecha</th>
                <th>Hora</th>
                <th>Equipo</th>
                <th>Tipo de ciclo</th>
                <th>Estado del proceso</th>
                <th>Cantidad</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.TbProId</td>
                    <td>@item.TbProNum1</td>
                    <td>@item.TbProFec?.ToString("dd/MM/yyyy")</td>
                    <td>@item.TbProHorIni?.ToString("HH:mm")</td>
                    <td>@item.TbProEquDen</td>
                    <td>@item.TbProTciDen</td>
                    <td>@item.IbProEstDen</td>
                    <td>@item.TbProCant</td>
                </tr>
            }
        </tbody>
    </table>
}
else if (ViewBag.FechaInicio != null && ViewBag.FechaFin != null)
{
    <div class="alert alert-warning">No se encontraron procesos para los filtros seleccionados.</div>
}
