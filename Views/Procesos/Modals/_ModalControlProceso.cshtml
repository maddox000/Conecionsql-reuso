<div id="modalControlProceso" class="modal-overlay">
    <div class="modal-box">

        <!-- CAMPOS OCULTOS -->
        <input type="hidden" id="tbProId" />
        <input type="hidden" id="tbProDetPteId" />
        <input type="hidden" id="ubicacionOriginal" />
        <input type="hidden" id="modoModal" />

        <!-- HEADER -->
        <div class="modal-header">
            Datos de controles de proceso
        </div>

        <!-- BODY -->
        <div class="modal-body">

            <div class="form-row">
                <label for="tipoControl">Tipo de control</label>
                <input type="text" id="tipoControl" class="form-control" autocomplete="off" />
                <div id="listaTipoControl" class="lista-busqueda"></div>
            </div>

            <div class="form-row">
                <label for="identificacion">Identificación</label>
                <input type="text" id="identificacion" class="form-control" />
            </div>

            <div class="form-row">
                <label for="marca">Marca</label>
                <input type="text" id="marca" value="TERRAGENE" class="form-control" readonly />
            </div>

            <div class="form-row">
                <label for="producto">Producto</label>
                <input type="text" id="producto" value="NO REGISTRA" class="form-control" readonly />
            </div>

            <div class="form-row">
                <label for="lote">Lote</label>
                <input type="text" id="lote" value="0" class="form-control" readonly />
            </div>

            <div class="form-row">
                <label for="vencimiento">Vencimiento</label>
                <input type="text" id="vencimiento" value="" class="form-control" readonly />
            </div>

            <div class="form-row">
                <label for="ubicacion">Ubicación encámara</label>
                <select id="ubicacion" class="form-control">
                    <option value="">-- Seleccionar --</option>
                </select>
            </div>

            <div class="form-row">
                <label for="codigoBarras">Escanear código de barras</label>
                <input type="text" id="codigoBarras" value="NO REGISTRA" class="form-control" readonly />
            </div>

        </div>

        <!-- FOOTER -->
        <div class="modal-footer">
            <button type="button"
                    id="btnGuardarControl"
                    class="btn btn-primary">
                Registrar
            </button>
            <button type="button"
                    id="btnCancelarControl"
                    class="btn btn-secondary"
                    onclick="cerrarModalControlProceso()">
                Cancelar
            </button>
        </div>

    </div>
</div>

<script>
    let tiposControlData = [];

    function cargarTiposControl() {
        fetch('/TbProControl/ObtenerTiposControl')
            .then(res => res.json())
            .then(data => {
                tiposControlData = data || [];

                const input = document.getElementById("tipoControl");
                const lista = document.getElementById("listaTipoControl");

                if (!input || !lista) return;

                input.value = "";
                input.dataset.id = "";
                lista.innerHTML = "";
                lista.style.display = "none";
            })
            .catch(err => console.error("Error cargando tipos de control:", err));
    }

    function filtrarTiposControl(texto) {
        const lista = document.getElementById("listaTipoControl");
        const input = document.getElementById("tipoControl");

        if (!lista || !input) return;

        const filtro = (texto || "").trim().toLowerCase();

        lista.innerHTML = "";

        if (!filtro) {
            lista.style.display = "none";
            return;
        }

        const resultados = tiposControlData.filter(x =>
            (x.iB_PTE_DEN || "").toLowerCase().startsWith(filtro)
        );

        if (resultados.length === 0) {
            lista.style.display = "none";
            return;
        }

        resultados.forEach(item => {
            const div = document.createElement("div");
            div.className = "item-busqueda";
            div.textContent = item.iB_PTE_DEN;

            div.addEventListener("click", function () {
                input.value = item.iB_PTE_DEN;
                input.dataset.id = item.iB_PTE_ID;
                lista.innerHTML = "";
                lista.style.display = "none";
            });

            lista.appendChild(div);
        });

        lista.style.display = "block";
    }

    function cargarUbicacionesControl() {
        fetch('/TbProControl/ObtenerUbicacionesControl')
            .then(res => res.json())
            .then(data => {
                const combo = document.getElementById("ubicacion");
                if (!combo) return;

                combo.innerHTML = '<option value="">-- Seleccionar --</option>';

                data.forEach(item => {
                    const option = document.createElement("option");
                    option.value = item.iB_PTES_UBI_ID;
                    option.text = item.iB_PTES_UBI_DEN;
                    combo.appendChild(option);
                });

                const ubicacionOriginal = document.getElementById("ubicacionOriginal").value;
                if (ubicacionOriginal) {
                    combo.value = ubicacionOriginal;
                }
            })
            .catch(err => console.error("Error cargando ubicaciones:", err));
    }

    function abrirModalControlProceso(tbProId, posicion = null) {
        cargarTiposControl();

        if (posicion !== null) {
            document.getElementById("ubicacionOriginal").value = posicion;
        } else {
            document.getElementById("ubicacionOriginal").value = "";
        }

        cargarUbicacionesControl();

        document.getElementById("tbProId").value = tbProId;
        document.getElementById("modalControlProceso").style.display = "flex";
        document.getElementById("modoModal").value = "alta";
        document.getElementById("tbProDetPteId").value = "";
        document.getElementById("identificacion").value = "";

        setTimeout(() => {
            document.getElementById("tipoControl")?.focus();
        }, 100);
    }

    function cerrarModalControlProceso() {
        document.getElementById("modalControlProceso").style.display = "none";

        document.getElementById("tbProDetPteId").value = "";
        document.getElementById("identificacion").value = "";
        document.getElementById("ubicacionOriginal").value = "";
        document.getElementById("modoModal").value = "";

        const tipoControl = document.getElementById("tipoControl");
        if (tipoControl) {
            tipoControl.value = "";
            tipoControl.dataset.id = "";
        }

        const lista = document.getElementById("listaTipoControl");
        if (lista) {
            lista.innerHTML = "";
            lista.style.display = "none";
        }
    }

    function marcarNodo(posicion) {
        document.querySelectorAll(".proceso-diagram .node")
            .forEach(n => {
                if (n.textContent.trim() === String(posicion)) {
                    n.classList.add("activo");
                }
            });

        if (String(posicion) === "28") {
            document.querySelector(".proceso-bd")?.classList.add("activo");
        }
    }

    document.addEventListener("DOMContentLoaded", function () {

        const btnGuardarControl = document.getElementById("btnGuardarControl");
        const tipoControl = document.getElementById("tipoControl");
        const identificacion = document.getElementById("identificacion");
        const ubicacion = document.getElementById("ubicacion");
        const listaTipoControl = document.getElementById("listaTipoControl");

        if (tipoControl) {
            tipoControl.addEventListener("input", function () {
                filtrarTiposControl(tipoControl.value);
            });

            tipoControl.addEventListener("keydown", function (e) {
                if (e.key === "Enter") {
                    e.preventDefault();
                    const primerItem = listaTipoControl?.querySelector(".item-busqueda");
                    if (primerItem) {
                        primerItem.click();
                        identificacion?.focus();
                    }
                }
            });

            tipoControl.addEventListener("focus", function () {
                if (tipoControl.value.trim()) {
                    filtrarTiposControl(tipoControl.value);
                }
            });
        }

        document.addEventListener("click", function (e) {
            if (!e.target.closest("#tipoControl") && !e.target.closest("#listaTipoControl")) {
                if (listaTipoControl) {
                    listaTipoControl.innerHTML = "";
                    listaTipoControl.style.display = "none";
                }
            }
        });

        if (identificacion) {
            identificacion.addEventListener("keydown", function (e) {
                if (e.key === "Enter") {
                    e.preventDefault();
                    ubicacion?.focus();
                }
            });
        }

        async function guardarControlProceso() {
            try {

                const tipoControl = document.getElementById("tipoControl");
                const ubicacion = document.getElementById("ubicacion");
                const tbProIdInput = document.getElementById("tbProId");
                const tbProDetPteIdInput = document.getElementById("tbProDetPteId");
                const identificacionInput = document.getElementById("identificacion");
                const marcaInput = document.getElementById("marca");
                const productoInput = document.getElementById("producto");
                const loteInput = document.getElementById("lote");
                const vencimientoInput = document.getElementById("vencimiento");
                const codigoBarrasInput = document.getElementById("codigoBarras");
                const modoModalInput = document.getElementById("modoModal");

                const tbProId = parseInt(tbProIdInput.value || "0");

                const data = {
                    TB_PRO_ID: tbProId,
                    TB_PRO_DET_PTE_ID: parseInt(tbProDetPteIdInput?.value || "0"),
                    TB_PRO_PTE_ID: parseInt(tipoControl.dataset.id || "0"),
                    TB_PRO_PTE_DEN: tipoControl.value || "",
                    TB_PRO_PTE_IDE: identificacionInput?.value || "",
                    TB_PRO_DET_TES_UBI_ID: parseInt(ubicacion.value || "0"),
                    TB_PRO_DET_TES_UBI_DEN: ubicacion.value
                        ? ubicacion.options[ubicacion.selectedIndex].text
                        : "",
                    TB_PRO_DET_PTE_PROD_BRAND: marcaInput?.value || "",
                    TB_PRO_DET_PTE_PROD_NAME: productoInput?.value || "",
                    TB_PRO_PTE_LOT: loteInput?.value || "0",
                    TB_PRO_PTE_VEN: vencimientoInput?.value || null,
                    TB_PRO_DET_PTE_TICKET_NUMB: codigoBarrasInput?.value || "NO REGISTRA",
                    TB_PRO_PTE_CANT: 1,
                    MODO_MODAL: modoModalInput?.value || "alta"
                };

            const response = await fetch("/TbProControl/Insertar", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (!result.ok && !result.success) {
                    alert(result.mensaje || "❌ Error al guardar.");
                    return;
                }

            if (result.ok || result.success) {
                cerrarModalControlProceso();

                const tbProId = document.getElementById("tbProId").value;

                const response = await fetch(`/TbProControl/ObtenerControlesPorProceso?tbProId=${tbProId}`);
                const json = await response.json();

                console.log("CONTROLES:", json);
            }


        // 🔥 LLAMAMOS A LA VISTA PRINCIPAL
        if (window.cargarControlesProceso) {
            window.cargarControlesProceso();
        }
    }

            } catch (error) {
                console.error("Error al guardar control:", error);
                alert("❌ Error inesperado al guardar.");
            }
        }

        if (btnGuardarControl) {
            btnGuardarControl.addEventListener("click", guardarControlProceso);
        }
    });
</script>