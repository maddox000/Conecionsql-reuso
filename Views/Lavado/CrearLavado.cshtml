@model ConexionSql.Models.Lavado.TbProLavFormDto

@{
    ViewData["Title"] = "Crear Lavado";
    var fechaHoy = DateTime.Now.ToString("yyyy-MM-dd");
    var horaInicio = DateTime.Now.ToString("HH:mm");
}

<link rel="stylesheet" href="~/css/views/crear-lavado.css" asp-append-version="true" />

<div class="bx-card lavado-demo">
    <div class="lavado-banner">Proceso de lavado</div>

    <form id="formCrearLavado" onsubmit="return false;">

        <input type="hidden" id="fechaLavado" value="@fechaHoy" />
        <input type="hidden" id="horaInicio" value="@horaInicio" />

        <div class="lavado-grid">
            <div class="lavado-panel">
                <div class="lavado-kv">
                    <div class="k">Número de proceso</div>
                    <div class="v">Nuevo</div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Usuario</div>
                    <div class="v">@ViewBag.UsuarioLogueado</div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Cargo</div>
                    <div class="v">@((string?)ViewBag.UserCargo ?? "-")</div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Cantidad total</div>
                    <div class="v">
                        <input type="text" class="form-control" id="cantidadTotal" value="0" readonly />
                    </div>
                </div>

                <div class="lavado-title">Datos del proceso</div>

                <div class="lavado-kv">
                    <div class="k">Detergente</div>
                    <div class="v">
                        <input type="text" id="Detergente" name="Detergente" class="form-control" value="Ej: Detergente X" />
                    </div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Lote</div>
                    <div class="v">
                        <input type="text" id="Lote" name="Lote" class="form-control" value="NO REGISTRADO" />
                    </div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Vencimiento</div>
                    <div class="v">
                        <input type="text" id="Vencimiento" name="Vencimiento" class="form-control" value="NO REGISTRADO" />
                    </div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Número de ciclo</div>
                    <div class="v">
                        <input type="number" id="NumeroCiclo" name="NumeroCiclo" class="form-control" value="0" min="0" />
                    </div>
                </div>
            </div>

            <div class="lavado-panel">
                <div class="lavado-kv">
                    <div class="k">Fecha</div>
                    <div class="v">@fechaHoy @horaInicio</div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Tipo de lavado</div>
                    <div class="v">
                        <select class="form-select" asp-for="TipoLavadoId" asp-items="Model.TiposLavado" id="TipoLavadoId" required>
                            <option value="">-- Seleccionar tipo --</option>
                        </select>
                    </div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Equipo</div>
                    <div class="v">
                        <select class="form-select" asp-for="EquipoId" asp-items="Model.Equipos" id="EquipoId" required>
                            <option value="">-- Seleccionar equipo --</option>
                        </select>
                    </div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Tipo de ciclo</div>
                    <div class="v">
                        <select class="form-select" asp-for="TipoCicloId" asp-items="Model.TiposCiclo" id="TipoCicloId" required>
                            <option value="">-- Seleccionar ciclo --</option>
                        </select>
                    </div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Dilución</div>
                    <div class="v">
                        <input type="text" id="Dilucion" name="Dilucion" class="form-control" value="NO REGISTRADO" />
                    </div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Tiempo de contacto</div>
                    <div class="v">
                        <input type="text" id="TiempoContacto" name="TiempoContacto" class="form-control" value="NO REGISTRADO" />
                    </div>
                </div>
            </div>
        </div>

        <div class="lavado-observ">
            <div class="k lavado-observ-label">Observaciones</div>
            <textarea id="Observaciones" name="Observaciones">NO REGISTRA</textarea>
        </div>

        <div id="mensajeLavado" class="mt-3 text-danger"></div>
        <button type="button" class="btn btn-primary" onclick="guardarLavado()">
            Registrar
        </button>

    </form>
</div>
<!--termina cabecera -->

<div class="lavado-table-wrap lavado-table-wrap-auto">
    <div class="lavado-table-head-title">Materiales procesados</div>

    <table class="lavado-table">
        <thead>
            <tr>
                <th>Codigo etiqueta</th>
                <th>Denominacion</th>
                <th>Sector</th>
                <th>Codigo reuso</th>
                <th>Recibidos</th>
                <th>En proceso</th>
                <th>Sin procesar</th>
                <th>Cantidad</th>
                <th>Eliminar</th>
            </tr>
        </thead>
        
    </table>
</div>

<div class="lavado-table-wrap">
    <table class="lavado-table">
        <thead>
            <tr>
                <th>Codigo etiqueta</th>
                <th>Denominacion</th>
                <th>Sector</th>
                <th>Codigo reuso</th>
                <th>Recibidos</th>
                <th>En proceso</th>
                <th>Sin procesar</th>
                <th>Cantidad</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td><input type="text" class="form-control" /></td>
                <td><input type="text" class="form-control" /></td>
                <td><input type="text" class="form-control" /></td>
                <td><input type="text" class="form-control" /></td>
                <td><input type="text" class="form-control" /></td>
                <td><input type="text" class="form-control" /></td>
                <td><input type="text" class="form-control" /></td>
                <td><input type="text" class="form-control" /></td>
            </tr>
        </tbody>
    </table>

    <div class="lavado-actions mt-2">
        <button type="button" class="btn btn-primary">Registrar</button>
        <button type="button" class="btn btn-outline-primary">Nuevo</button>
        <button type="button" class="btn btn-outline-primary">Editar</button>
        <button type="button" class="btn btn-secondary">Cerrar</button>
    </div>
</div>

<div id="contenedorSubform" class="mt-5"></div>

@section Scripts {
    <script>
        async function guardarLavado() {
            const data = {
                TbProLavFec: document.getElementById("fechaLavado").value,
                TbProLavHorIni: document.getElementById("horaInicio").value,
                TipoLavadoId: parseInt(document.getElementById("TipoLavadoId").value),
                EquipoId: parseInt(document.getElementById("EquipoId").value),
                TipoCicloId: parseInt(document.getElementById("TipoCicloId").value),
                TipoLavadoDen: document.getElementById("TipoLavadoId").selectedOptions[0]?.text,
                EquipoDen: document.getElementById("EquipoId").selectedOptions[0]?.text,
                TipoCicloDen: document.getElementById("TipoCicloId").selectedOptions[0]?.text
            };

            if (!data.TipoLavadoId || !data.EquipoId || !data.TipoCicloId) {
                document.getElementById("mensajeLavado").innerText = "⚠️ Complete todos los campos.";
                return;
            }

            const resp = await fetch('/Lavado/Insertar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const json = await resp.json();

            if (json.success) {
                window.location.href = `/TbProLavDet/SubFormulario?id=${json.tbProLavId}`;
            } else {
                document.getElementById("mensajeLavado").innerText = json.mensaje || "❌ Error al guardar.";
            }
        }

        document.getElementById("TipoLavadoId").addEventListener("change", async function () {
            const comboEquipo = document.getElementById("EquipoId");
            const comboCiclo = document.getElementById("TipoCicloId");

            comboEquipo.innerHTML = '<option value="">-- Cargando equipos... --</option>';
            comboCiclo.innerHTML = '<option value="">-- Cargando ciclos... --</option>';

            const resp = await fetch(`/Lavado/ObtenerEquiposPorTipo`);
            const data = await resp.json();

            comboEquipo.innerHTML = '<option value="">-- Seleccionar equipo --</option>';
            data.forEach(e => {
                const opt = document.createElement("option");
                opt.value = e.id;
                opt.text = e.nombre;
                comboEquipo.appendChild(opt);
            });

            const respCiclos = await fetch(`/Lavado/ObtenerTiposCiclo`);
            const dataCiclos = await respCiclos.json();

            comboCiclo.innerHTML = '<option value="">-- Seleccionar ciclo --</option>';
            dataCiclos.forEach(c => {
                const opt = document.createElement("option");
                opt.value = c.id;
                opt.text = c.nombre;
                comboCiclo.appendChild(opt);
            });
        });
    </script>
    <script>
        localStorage.setItem("modulo_134_abierto", "1");

        window.addEventListener("beforeunload", function () {
            localStorage.removeItem("modulo_134_abierto");
        });
    </script>
}