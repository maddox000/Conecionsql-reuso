@model List<ConexionSql.Models.Lavado.TbProLavDetDto>

@if (Model != null && Model.Any())
{
    foreach (var item in Model)
    {
        <tr>
            <td>@item.TB_PRO_LAV_DET_REC_DET_ID</td>
            <td>@(item.TB_PRO_LAV_DET_REC_DET_MAT_DEN ?? "")</td>
            <td>@(item.TB_REC_SEC_DES_DEN ?? "")</td>
            <td>@(item.TB_PRO_LAV_DET_REC_DET_REU_ID ?? "")</td>
            <td>@(item.TB_PRO_LAV_DET_REC_DET_CANT ?? 0)</td>
            <td>@(item.TB_PRO_LAV_DET_REC_DET_PRO_TOT ?? 0)</td>
            <td>@(item.TB_PRO_LAV_DET_REC_DET_PRO_STOCK ?? 0)</td>
            <td>@(item.TB_PRO_LAV_DET_CANT ?? 0)</td>
        </tr>
    }
}
else
{
    <tr>
        <td colspan="8" class="text-center text-muted">
            ⚠️ No hay detalles cargados.
        </td>
    </tr>
}
