@model ConexionSql.Models.Lavado.TbProLavDetFormDto

<div class="subform-lavado mt-4">
   
    <link rel="stylesheet" href="~/css/views/crear-lavado.css" asp-append-version="true" />
    <!-- Cabecera del lavado -->
    <div class="bx-card lavado-demo">
        <div class="lavado-banner">Proceso de lavado</div>

        <div class="lavado-grid">

            <!-- Panel izquierdo -->
            <div class="lavado-panel">
                <div class="lavado-kv">
                    <div class="k">Número de proceso</div>
                    <div class="v">@Model.Cabecera.TbProLavId</div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Usuario</div>
                    <div class="v">@Model.Cabecera.TbProLavPerNom</div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Cargo</div>
                    <div class="v">@Model.Cabecera.TbProLavPerCarDen</div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Cantidad total</div>
                    <div class="v" id="cantidadTotal">@(Model.Cabecera.TbProLavUpro ?? 0)</div>
                </div>

                <div class="lavado-title">Datos del proceso</div>

                <div class="lavado-kv">
                    <div class="k">Detergente</div>
                    <div class="v">NO REGISTRADO</div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Lote</div>
                    <div class="v">NO REGISTRADO</div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Vencimiento</div>
                    <div class="v">NO REGISTRADO</div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Número de ciclo</div>
                    <div class="v">0</div>
                </div>
            </div>

            <!-- Panel derecho -->
            <div class="lavado-panel">
                <div class="lavado-kv">
                    <div class="k">Fecha</div>
                    <div class="v">
                        @Model.Cabecera.TbProLavFec?.ToString("yyyy-MM-dd")
                        @Model.Cabecera.TbProLavHorIni?.ToString(@"hh\:mm")
                    </div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Tipo de lavado</div>
                    <div class="v">@Model.Cabecera.TbProLavPtiDen</div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Equipo</div>
                    <div class="v">@Model.Cabecera.TbProLavEquDen</div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Tipo de ciclo</div>
                    <div class="v">@Model.Cabecera.TbProLavTciDen</div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Dilución</div>
                    <div class="v">NO REGISTRADO</div>
                </div>

                <div class="lavado-kv">
                    <div class="k">Tiempo de contacto</div>
                    <div class="v">NO REGISTRADO</div>
                </div>
            </div>
        </div>

        <div class="lavado-observ">
            <div class="k lavado-observ-label">Observaciones</div>
            <textarea readonly>@(Model.Cabecera.TbProLavObs ?? "NO REGISTRA")</textarea>
        </div>
    </div>

    <!--termina cabecera -->
    <!-- 📋 Tabla de detalles -->
    <!-- DETALLE ARRIBA -->
    <div class="lavado-table-wrap mt-4">
        <div class="lavado-title">Registro de materiales</div>

        <div id="contenedor-lavado-detalles">
            <table class="lavado-table">
                <thead>
                    <tr>
                        <th>Código etiqueta</th>
                        <th>Denominación</th>
                        <th>Sector</th>
                        <th>Código reuso</th>
                        <th>Recibidos</th>
                        <th>En proceso</th>
                        <th>Sin procesar</th>
                        <th>Cantidad</th>
                    </tr>
                </thead>
                <tbody id="tbody-lavado-detalles">
                    @await Html.PartialAsync("~/Views/Lavado/_DetalleTabla.cshtml", Model.Detalles)
                </tbody>
            </table>
        </div>
    </div>
        <!-- 📋 Tabla de detalles -->


<div class="lavado-operativo">
    <form id="formLavadoDetalle" onsubmit="return false;">
        <input type="hidden" id="tbProLavId" value="@Model.Cabecera.TbProLavId" />

        <table class="lavado-table">
            <thead>
                <tr>
                    <th>Código etiqueta</th>
                    <th>Denominación</th>
                    <th>Sector</th>
                    <th>Código reuso</th>
                    <th>Recibidos</th>
                    <th>En proceso</th>
                    <th>Sin procesar</th>
                    <th>Cantidad</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <input type="text"
                               id="tbRecDetId"
                               class="form-control form-control-sm"
                               autocomplete="off"
                               required />
                    </td>

                    <td><input type="text" id="materialNombre" class="form-control form-control-sm" readonly /></td>
                    <td><input type="text" id="sector" class="form-control form-control-sm" readonly /></td>
                    <td><input type="text" id="codigoReuso" class="form-control form-control-sm" readonly /></td>
                    <td><input type="number" id="recibidos" class="form-control form-control-sm" readonly /></td>
                    <td><input type="number" id="enProceso" class="form-control form-control-sm" readonly /></td>
                    <td><input type="number" id="sinProcesar" class="form-control form-control-sm" readonly /></td>

                    <td>
                        <input type="text"
                               id="cantidad"
                               class="form-control form-control-sm"
                               min=""
                               required />
                    </td>
                </tr>
            </tbody>
        </table>

        <div class="mt-2 lavado-operativo-actions">
            <button type="submit" class="btn btn-primary btn-sm">Guardar</button>
        </div>

        <div id="mensajeOk" class="text-success mt-2" style="display:none;"></div>
        <div id="mensajeError" class="text-danger mt-2" style="display:none;"></div>
    </form>
</div>





<script>
    document.addEventListener("DOMContentLoaded", function () {
        const inputEtiqueta = document.getElementById("tbRecDetId");
        const inputMaterial = document.getElementById("materialNombre");
        const inputCantidad = document.getElementById("cantidad");
        const inputCabecera = document.getElementById("tbProLavId");
        const msgOk = document.getElementById("mensajeOk");
        const msgErr = document.getElementById("mensajeError");

        let etiquetaId = 0;
        let materialId = 0;
        let materialNombre = "";
        let stockDisponible = 0;

        inputEtiqueta.focus();

        inputEtiqueta.addEventListener("keydown", function (e) {
            if (e.key === "Enter") {
                e.preventDefault();
                buscarEtiqueta();
            }
        });

        document.getElementById("formLavadoDetalle").addEventListener("submit", function (e) {
            e.preventDefault();
            guardarDetalle();
        });

        function buscarEtiqueta() {
            etiquetaId = parseInt(inputEtiqueta.value);
            if (!etiquetaId || etiquetaId <= 0) {
                mostrarError("⚠️ Código inválido.");
                return;
            }

            ocultarMensajes();

                    fetch(`/TbProLavDet/ObtenerMaterial?tbRecDetId=${etiquetaId}`)
                        .then(res => res.json())
                        .then(data => {
                                    if (data.success) {
                                    materialId = data.materialId;
                                    materialNombre = data.nombre ?? "";
                                    stockDisponible = data.sinProcesar ?? 0;

                                    inputMaterial.value = materialNombre;
                                    document.getElementById("sector").value = data.sector ?? "";
                                    document.getElementById("codigoReuso").value = data.codigoReuso ?? "";
                                    document.getElementById("recibidos").value = data.recibidos ?? 0;
                                    document.getElementById("enProceso").value = data.enProceso ?? 0;
                                    document.getElementById("sinProcesar").value = data.sinProcesar ?? 0;

                                    inputCantidad.value = "1";
                                    inputCantidad.focus();
                            } else {
                                mostrarError(data.mensaje || "❌ No se encontró la etiqueta.");
                            }
                        })
                        .catch(() => mostrarError("❌ Error al buscar la etiqueta."));
                
        }

        function guardarDetalle() {
            ocultarMensajes();

            const cantidad = parseInt(inputCantidad.value);
            const cabeceraId = parseInt(inputCabecera.value);

            if (!etiquetaId || !materialId || !cantidad || cantidad < 1 || !cabeceraId) {
                mostrarError("⚠️ Todos los campos son obligatorios.");
                return;
            }

            if (cantidad > stockDisponible) {
                mostrarError(`❌ Stock insuficiente. Disponible: ${stockDisponible}`);
                return;
            }

            const datos = {
                TB_PRO_LAV_ID: cabeceraId,
                TB_PRO_LAV_DET_REC_DET_ID: etiquetaId,
                TB_PRO_LAV_DET_MAT_ID: materialId,
                TB_PRO_LAV_DET_MAT_DEN: materialNombre,
                TB_PRO_LAV_DET_CANT: cantidad
            };

            fetch("/TbProLavDet/Insertar", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(datos)
            })
                .then(res => res.json())
                .then(data => {
                        if (data.success) {
                        mostrarOk(data.mensaje || "✅ Detalle agregado correctamente.");

                        inputEtiqueta.value = "";
                        inputMaterial.value = "";
                        document.getElementById("sector").value = "";
                        document.getElementById("codigoReuso").value = "";
                        document.getElementById("recibidos").value = "";
                        document.getElementById("enProceso").value = "";
                        document.getElementById("sinProcesar").value = "";

                        inputCantidad.value = "1";

                        etiquetaId = 0;
                        materialId = 0;
                        materialNombre = "";
                        stockDisponible = 0;

                    document.getElementById("tbody-lavado-detalles").innerHTML = data.html;

                    const totalCell = document.getElementById("cantidadTotal");
                    if (totalCell) {
                        totalCell.innerText = data.total ?? 0;
                    }

                    inputEtiqueta.focus();
                } else {
                    mostrarError(data.mensaje || "❌ Error al guardar.");
                }
            })
                .catch(() => mostrarError("❌ Error inesperado."));
        }

        function mostrarOk(texto) {
            msgOk.innerText = texto;
            msgOk.style.display = "block";
            msgErr.style.display = "none";
        }

        function mostrarError(texto) {
            msgErr.innerText = texto;
            msgErr.style.display = "block";
            msgOk.style.display = "none";
        }

        function ocultarMensajes() {
            msgOk.style.display = "none";
            msgErr.style.display = "none";
        }
    });
</script>
