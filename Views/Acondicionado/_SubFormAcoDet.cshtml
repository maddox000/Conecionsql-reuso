@model ConexionSql.Models.Acondicionado.TbProAcoDetFormDto

<!-- 🧪 Subformulario de Acondicionado -->
<div class="subform-acondicionado mt-4">
    <h4>➕ Agregar Detalle desde Etiqueta</h4>

    <!-- 🧾 Cabecera del proceso -->
    <table class="table table-bordered mt-3">
        <tr><th>ID</th><td>@Model.Cabecera.TbProAcoId</td></tr>
        <tr><th>Personal</th><td>@Model.Cabecera.TbProAcoPerNom</td></tr>
    </table>

    <form id="formAcoDetalle" onsubmit="return false;">
        <!-- 🛠️ Campo oculto con el ID de la cabecera de acondicionado -->
        <input type="hidden" id="tbProAcoId" value="@Model.Cabecera.TbProAcoId" />

        <!-- 🏷️ Código de etiqueta -->
        <div class="form-group">
            <label for="tbRecDetId">Código de etiqueta</label>
            <input type="number" class="form-control" id="tbRecDetId" name="tbRecDetId" placeholder="Ingrese código y presione Enter" required />
        </div>

        <!-- 🧾 Nombre del material -->
        <div class="form-group mt-2">
            <label for="materialNombre">Material</label>
            <input type="text" class="form-control" id="materialNombre" name="materialNombre" readonly />
        </div>

        <!-- 🔢 Cantidad -->
        <div class="form-group mt-2">
            <label for="cantidad">Cantidad a emplear</label>
            <input type="number" class="form-control" id="cantidad" name="cantidad" min="1" step="1" placeholder="Cantidad a procesar" required />
        </div>
    </form>

    <!-- 🗨️ Mensajes -->
    <div id="mensajeAco" class="mt-3 text-success"></div>
</div>

<!-- 📋 Tabla de detalles cargados -->
<div id="contenedor-aco-detalles" class="mt-4">
    @await Html.PartialAsync("~/Views/Acondicionado/_DetalleTablaAco.cshtml", Model.Detalles)
</div>

<!-- 📜 Script -->
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const inputEtiqueta = document.getElementById("tbRecDetId");
        const inputCantidad = document.getElementById("cantidad");
        const inputCabecera = document.getElementById("tbProAcoId");
        const inputMaterial = document.getElementById("materialNombre");
        const mensaje = document.getElementById("mensajeAco");

        inputEtiqueta.addEventListener("keydown", function (event) {
            if (event.key === "Enter") {
                event.preventDefault();
                const idEtiqueta = parseInt(inputEtiqueta.value);
                if (!Number.isInteger(idEtiqueta)) {
                    mensaje.innerText = "❌ Código inválido.";
                    mensaje.className = "text-danger mt-3";
                    inputEtiqueta.focus();
                    return;
                }

                fetch(`/TbProAcoDet/ObtenerMaterial?tbRecDetId=${idEtiqueta}`)
                    .then(res => res.json())
                    .then(data => {
                        inputMaterial.value = data.success ? data.nombre : "No encontrado";
                        inputCantidad.focus();
                    })
                    .catch(() => {
                        inputMaterial.value = "Error";
                        inputCantidad.focus();
                    });
            }
        });

        inputCantidad.addEventListener("keydown", function (event) {
            if (event.key === "Enter") {
                event.preventDefault();
                const tbRecDetId = parseInt(inputEtiqueta.value);
                const cantidad = parseInt(inputCantidad.value);
                const tbProAcoId = parseInt(inputCabecera.value);

                if (!Number.isInteger(tbRecDetId) || !Number.isInteger(cantidad) || cantidad < 1 || !Number.isInteger(tbProAcoId)) {
                    mensaje.innerText = "❌ Ingrese todos los datos correctamente.";
                    mensaje.className = "text-danger mt-3";
                    return;
                }

                fetch(`/TbProAcoDet/Insertar?tbRecDetId=${tbRecDetId}&cantidad=${cantidad}&tbProAcoId=${tbProAcoId}`, {
                    method: "POST"
                })
                .then(res => res.json())
                .then(result => {
                    mensaje.innerText = result.success ? result.mensaje : "❌ " + result.mensaje;
                    mensaje.className = result.success ? "text-success mt-3" : "text-danger mt-3";

                    if (result.success) {
                        document.getElementById("formAcoDetalle").reset();
                        inputMaterial.value = "";
                        if (result.html) {
                            document.getElementById("contenedor-aco-detalles").innerHTML = result.html;
                        }
                    }
                })
                .catch(err => {
                    mensaje.innerText = "❌ Error al guardar: " + err.message;
                    mensaje.className = "text-danger mt-3";
                });
            }
        });
    });
</script>
