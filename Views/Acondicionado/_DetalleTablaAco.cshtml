@model List<ConexionSql.Models.Acondicionado.TbProAcoDetDto>

@if (Model != null && Model.Any())
{
    foreach (var item in Model)
    {
        <tr>
            <td>@(item.TbProAcoDetRecDetId ?? 0)</td>
            <td>@(item.TbProAcoDetMatDen ?? "")</td>
            <td>@(item.TbProAcoDetSecDesDen ?? "")</td>
            <td>@(item.TbProAcoDetReuId?.ToString() ?? "")</td>
            <td>@(item.TbProAcoDetMatEtiDen ?? "")</td>
            <td>@(item.TbProAcoDetRecDetCant ?? 0)</td>
            <td>@(item.TbProAcoDetEmpTot ?? 0)</td>
            <td>@(item.TbProAcoDetEmpStock ?? 0)</td>
            <td>@(item.TbProAcoDetCant ?? 0)</td>
        </tr>
    }
}
else
{
    <tr>
        <td colspan="9" class="text-center text-muted">
            ⚠️ No hay detalles cargados.
        </td>
    </tr>
}