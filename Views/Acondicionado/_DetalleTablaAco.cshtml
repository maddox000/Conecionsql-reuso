@model List<ConexionSql.Models.Acondicionado.TbProAcoDetDto>

<table class="table table-sm table-bordered table-striped">
    <thead class="thead-dark">
        <tr>
            <th style="width: 10%;">ID</th>
            <th style="width: 45%;">Material</th>
            <th style="width: 20%;">Cantidad</th>
            <th style="width: 25%;">Acción</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.TbProAcoDetId</td>
                    <td>@item.TbProAcoDetMatDen</td>
                    <td>@item.TbProAcoDetCant</td>
                    <td>
                        <button class="btn btn-sm btn-danger" onclick="eliminarAcoDetalle(@item.TbProAcoDetId)">
                            🗑️ Eliminar
                        </button>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="4" class="text-center text-muted">⚠️ No hay detalles cargados.</td>
            </tr>
        }
    </tbody>
</table>
