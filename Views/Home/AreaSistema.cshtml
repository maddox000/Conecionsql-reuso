            <div>
                <label style="display: block; font-weight: 600; font-size: 0.85rem; color: #666; margin-bottom: 5px;">Denominación *</label>
                <input type="text" id="editarProductoDenominacion" name="denominacion" placeholder="Nombre del producto" required style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px; font-size: 0.9rem; box-sizing: border-box;"/>
            </div>
            
            <div>
                <label style="display: block; font-weight: 600; font-size: 0.85rem; color: #666; margin-bottom: 5px;">Tipo *</label>
                <input type="text" id="editarProductoTipo" name="tipo" placeholder="BANDEJA, CAJA, etc." required style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px; font-size: 0.9rem; box-sizing: border-box;"/>
            </div>
            
            <div>
                <label style="display: block; font-weight: 600; font-size: 0.85rem; color: #666; margin-bottom: 5px;">Ubicación</label>
                <input type="text" id="editarProductoUbicacion" name="ubicacion" placeholder="Ubicación física" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px; font-size: 0.9rem; box-sizing: border-box;"/>
            </div>
            
            <div>
                <label style="display: block; font-weight: 600; font-size: 0.85rem; color: #666; margin-bottom: 5px;">Contenido (Cantidad) *</label>
                <input type="number" id="editarProductoContenido" name="contenido" placeholder="1" min="1" required style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px; font-size: 0.9rem; box-sizing: border-box;"/>
            </div>
            
            <div>
                <label style="display: block; font-weight: 600; font-size: 0.85rem; color: #666; margin-bottom: 5px;">Catálogo</label>
                <input type="text" id="editarProductoCatalogo" name="catalogo" placeholder="Referencia catálogo" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px; font-size: 0.9rem; box-sizing: border-box;"/>
            </div>
            
            <div style="grid-column: 1/-1;">
                <label style="display: flex; align-items: center; gap: 8px; font-weight: 600; font-size: 0.85rem; color: #666; cursor: pointer;">
                    <input type="checkbox" id="editarProductoControlado" name="controlado" style="width: 18px; height: 18px; cursor: pointer;"/>
                    <span>Controlado</span>
                </label>
            </div>
            
            <div style="grid-column: 1/-1;">
                <label style="display: flex; align-items: center; gap: 8px; font-weight: 600; font-size: 0.85rem; color: #666; cursor: pointer;">
                    <input type="checkbox" id="editarProductoOculto" name="oculto" style="width: 18px; height: 18px; cursor: pointer;"/>
                    <span>Ocultar</span>
                </label>
            </div>
            
            <div style="grid-column: 1/-1; display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 10px;">
                <button type="button" id="btnGuardarEdicion" data-info-basica-auth="true" onclick="guardarEdicion()" style="padding: 12px; background-color: #2c3e50; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: 600; font-size: 0.9rem;">Guardar cambios</button>
                <button type="button" id="btnCancelarEditar" style="padding: 12px; background-color: #7f8c8d; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: 600; font-size: 0.9rem;">Cancelar</button>
            </div>
        </form>
    </div>
</div>

<script>
    console.log('>> Script cargado');

var productoSeleccionado = null;
var btnEditarProductoHabilitado = false;

// FUNCIÓN GLOBAL PARA GUARDAR EDICIÓN
function guardarEdicion() {
    console.log('>> guardarEdicion() llamada');
    
    const productoModificado = {
        id: parseInt(document.getElementById('editarProductoId').value),
        codigo: document.getElementById('editarProductoCodigo').value,
        denominacion: document.getElementById('editarProductoDenominacion').value,
        tipo: document.getElementById('editarProductoTipo').value,
        ubicacion: document.getElementById('editarProductoUbicacion').value || '',
        contenido: parseInt(document.getElementById('editarProductoContenido').value),
        catalogo: document.getElementById('editarProductoCatalogo').value || '',
        controlado: document.getElementById('editarProductoControlado').checked,
        oculto: document.getElementById('editarProductoOculto').checked
    };
    
    console.log('Enviando:', productoModificado);
    
    fetch('/Home/ModificarProducto', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(productoModificado)
    })
    .then(function(r) { return r.json(); })
    .then(function(result) {
        if (result.success) {
            alert('Producto modificado exitosamente');
            document.getElementById('modalEditarProducto').style.display = 'none';
            window.location.href = '/Home/AreaSistema?tipo=productos';
        } else {
            alert('Error: ' + result.message);
        }
    })
    .catch(function(e) { alert('Error de conexión: ' + e); });
}

// FUNCIÓN GLOBAL PARA ABRIR MODAL
function abrirModalEditar() {
    console.log('*** FUNCIÓN abrirModalEditar() EJECUTADA ***');
    
    const modalEditarProducto = document.getElementById('modalEditarProducto');
    console.log('Modal exists:', !!modalEditarProducto);
    
    if (!btnEditarProductoHabilitado) {
        alert('Por favor selecciona un producto primero');
        return;
    }
    
    if (!productoSeleccionado) {
        alert('No hay producto seleccionado');
        return;
    }
    
    console.log('Llenando formulario con:', productoSeleccionado);
    
    // Fill form
    document.getElementById('editarProductoId').value = productoSeleccionado.id || '';
    document.getElementById('editarProductoCodigo').value = productoSeleccionado.codigo || '';
    document.getElementById('editarProductoDenominacion').value = productoSeleccionado.denominacion || '';
    document.getElementById('editarProductoTipo').value = productoSeleccionado.tipo || '';
    document.getElementById('editarProductoUbicacion').value = productoSeleccionado.ubicacion || '';
    document.getElementById('editarProductoContenido').value = productoSeleccionado.contenido || '';
    document.getElementById('editarProductoCatalogo').value = productoSeleccionado.catalogo || '';
    
    const chk1 = document.getElementById('editarProductoControlado');
    const chk2 = document.getElementById('editarProductoOculto');
    if (chk1) chk1.checked = productoSeleccionado.controlado;
    if (chk2) chk2.checked = productoSeleccionado.oculto;
    
    console.log('Abriendo modal...');
    if (modalEditarProducto) {
        modalEditarProducto.style.display = 'flex';
        console.log('*** MODAL ABIERTO ***');
    }
}

// INICIALIZAR (compatible con SPA shell re-ejecución)
(function() {
    console.log('>> Inicializando script productos');
    
    const modalEditarProducto = document.getElementById('modalEditarProducto');
    const formEditarProducto = document.getElementById('formEditarProducto');
    const btnCerrarProductos = document.getElementById('btnCerrarProductos');

    // Product row selection
    document.querySelectorAll('.producto-fila').forEach(fila => {
        fila.addEventListener('click', function (e) {
            if (e.target.type === 'checkbox') return;
            
            document.querySelectorAll('.producto-fila').forEach(f => f.style.backgroundColor = '');
            this.style.backgroundColor = '#e8f4f8';
            
            productoSeleccionado = {
                id: this.getAttribute('data-producto-id'),
                codigo: this.getAttribute('data-codigo'),
                denominacion: this.getAttribute('data-denominacion'),
                tipo: this.getAttribute('data-tipo'),
                ubicacion: this.getAttribute('data-ubicacion'),
                contenido: this.getAttribute('data-contenido'),
                catalogo: this.getAttribute('data-catalogo') || '',
                controlado: this.getAttribute('data-controlado') === 'True',
                oculto: this.getAttribute('data-oculto') === 'True'
            };
            
            console.log('✓ Producto seleccionado:', productoSeleccionado);
            
            // Update detail panel
            document.getElementById('detalle-codigo-sistema').textContent = productoSeleccionado.id;
            document.getElementById('detalle-codigo-producto').textContent = productoSeleccionado.codigo;
            document.getElementById('detalle-denominacion').textContent = productoSeleccionado.denominacion;
            document.getElementById('detalle-catalogo').textContent = productoSeleccionado.tipo || '-';
            document.getElementById('detalle-contenido').textContent = productoSeleccionado.contenido;
            document.getElementById('detalle-ubicacion-depos').textContent = productoSeleccionado.ubicacion || '-';
            document.getElementById('detalle-ubicacion-actual').textContent = productoSeleccionado.ubicacion || '-';
            
            // Enable Edit button
            const btnEditarProducto = document.getElementById('btnEditarProducto');
            if (btnEditarProducto) {
                btnEditarProductoHabilitado = true;
                btnEditarProducto.disabled = false;
                btnEditarProducto.style.opacity = '1';
                btnEditarProducto.style.cursor = 'pointer';
                btnEditarProducto.style.pointerEvents = 'auto';
                btnEditarProducto.style.backgroundColor = '#2c3e50';
                btnEditarProducto.classList.remove('disabled');
                btnEditarProducto.removeAttribute('aria-disabled');
                console.log('✓ Botón Editar habilitado');
            }
        });
    });

    // Cancel edit
    const btnCancelarEditar = document.getElementById('btnCancelarEditar');
    if (btnCancelarEditar) {
        btnCancelarEditar.addEventListener('click', function () {
            if (modalEditarProducto) modalEditarProducto.style.display = 'none';
            if (formEditarProducto) formEditarProducto.reset();
        });
    }

    // Click outside modal
    if (modalEditarProducto) {
        modalEditarProducto.addEventListener('click', function (e) {
            if (e.target === modalEditarProducto) {
                modalEditarProducto.style.display = 'none';
                if (formEditarProducto) formEditarProducto.reset();
            }
        });
    }

    // Close button
    if (btnCerrarProductos) {
        btnCerrarProductos.addEventListener('click', function () {
            window.history.back();
        });
    }

    // Control reusos button
    var btnControlReusos = document.getElementById('btnControlReusos');
    if (btnControlReusos) {
        btnControlReusos.addEventListener('click', function () {
            var den = productoSeleccionado ? productoSeleccionado.denominacion : '';
            var url = '/Reusos' + (den ? '?denominacion=' + encodeURIComponent(den) : '');
            window.location.href = url;
        });
    }
    
    console.log('>> Inicialización completada');
})();

// === EQUIPOS: selección de fila y editar ===
(function() {
    var equipoFilas = document.querySelectorAll('.equipo-fila');
    if (!equipoFilas.length) return;

    var equipoSeleccionadoId = null;

    equipoFilas.forEach(function(fila) {
        fila.addEventListener('click', function(e) {
            if (e.target.type === 'checkbox' || e.target.tagName === 'A') return;
            seleccionarEquipo(this);
        });
    });

    document.querySelectorAll('.equipo-id-link').forEach(function(link) {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            seleccionarEquipo(this.closest('tr'));
        });
    });

    function seleccionarEquipo(fila) {
        equipoFilas.forEach(function(f) { f.style.backgroundColor = ''; });
        fila.style.backgroundColor = '#e8f4f8';
        equipoSeleccionadoId = fila.getAttribute('data-equipo-id');

        var btn = document.getElementById('btnEditarEquipo');
        if (btn) {
            btn.style.opacity = '1';
            btn.style.pointerEvents = 'auto';
        }
    }

    window.editarEquipoSeleccionado = function() {
        if (!equipoSeleccionadoId) {
            alert('Por favor seleccione un equipo primero.');
            return;
        }
        var url = '/Home/EditarEquipo?id=' + encodeURIComponent(equipoSeleccionadoId);
        window.abrirModalAccesoInfoBasica(url, 'Editar equipo');
    };
})();

// === EXPORTAR / IMPRIMIR ===
(function() {
    var btnExportar = document.getElementById('btnExportarPDF');
    if (!btnExportar) return;
    btnExportar.addEventListener('click', function(e) {
        e.preventDefault();
        window.print();
    });
})();

// === PROFESIONALES ===
(function() {
    var profFilas = document.querySelectorAll('.profesional-fila');
    if (!profFilas.length) return;

    // Click en fila para autocompletar panel superior
    profFilas.forEach(function(fila) {
        fila.addEventListener('click', function(e) {
            if (e.target.type === 'checkbox' || e.target.tagName === 'A') return;
            seleccionarProfesional(this);
        });
    });

    // Click en código de sistema (link)
    document.querySelectorAll('.prof-id-link').forEach(function(link) {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            seleccionarProfesional(this.closest('tr'));
        });
    });

    function seleccionarProfesional(fila) {
        profFilas.forEach(function(f) { f.style.backgroundColor = ''; });
        fila.style.backgroundColor = '#e8f4f8';

        var id = fila.getAttribute('data-prof-id');
        var apellido = fila.getAttribute('data-prof-apellido');
        var nombre = fila.getAttribute('data-prof-nombre');
        var sector = fila.getAttribute('data-prof-sector');
        var ocultar = fila.getAttribute('data-prof-ocultar') === 'True';

        document.getElementById('prof-codigo').textContent = id.padStart(5, '0');
        document.getElementById('prof-apellido').textContent = apellido;
        document.getElementById('prof-nombre').textContent = nombre;
        document.getElementById('prof-sector').textContent = sector;
        document.getElementById('prof-inhabilitado').checked = ocultar;
    }

    // Búsqueda en tabla
    var profBusqueda = document.getElementById('profBusqueda');
    var profCoincidencias = document.getElementById('profCoincidencias');
    if (profBusqueda) {
        profBusqueda.addEventListener('input', function() {
            var filtro = this.value.toLowerCase().trim();
            var count = 0;
            profFilas.forEach(function(fila) {
                var texto = fila.textContent.toLowerCase();
                if (!filtro || texto.indexOf(filtro) >= 0) {
                    fila.style.display = '';
                    count++;
                } else {
                    fila.style.display = 'none';
                }
            });
            if (profCoincidencias) profCoincidencias.value = count;
        });
    }

    // Exportar
    var btnExportarProf = document.getElementById('btnExportarProf');
    var menuExportarProf = document.getElementById('menuExportarProf');
    if (btnExportarProf && menuExportarProf) {
        btnExportarProf.addEventListener('click', function(e) {
            e.stopPropagation();
            menuExportarProf.style.display = menuExportarProf.style.display === 'none' ? 'block' : 'none';
        });
        document.addEventListener('click', function() {
            menuExportarProf.style.display = 'none';
        });
        var exportUrl = '@Url.Action("ExportarProfesionales", "Home")';
        document.getElementById('btnExportPdf').addEventListener('click', function() {
            menuExportarProf.style.display = 'none';
            window.open(exportUrl + '?modo=pdf', '_blank');
        });
        document.getElementById('btnExportImpresora').addEventListener('click', function() {
            menuExportarProf.style.display = 'none';
            window.open(exportUrl + '?modo=impresora', '_blank');
        });
    }

    // Cerrar
    var btnCerrarProf = document.getElementById('btnCerrarProf');
    if (btnCerrarProf) {
        btnCerrarProf.addEventListener('click', function() {
            window.BaxenShell.navigate('/', true);
        });
    }
})();

// === PROVEEDORES ===
(function() {
    var provFilas = document.querySelectorAll('.proveedor-fila');
    if (!provFilas.length) return;

    provFilas.forEach(function(fila) {
        fila.addEventListener('click', function(e) {
            if (e.target.type === 'checkbox') return;
            provFilas.forEach(function(f) { f.style.backgroundColor = ''; });
            this.style.backgroundColor = '#e8f4f8';
        });
    });

    var btnCerrarProv = document.getElementById('btnCerrarProv');
    if (btnCerrarProv) {
        btnCerrarProv.addEventListener('click', function() {
            window.BaxenShell.navigate('/', true);
        });
    }
})();

// === SECTORES ===
(function() {
    var secFilas = document.querySelectorAll('.sector-fila');
    if (!secFilas.length) return;

    secFilas.forEach(function(fila) {
        fila.addEventListener('click', function(e) {
            if (e.target.type === 'checkbox') return;
            secFilas.forEach(function(f) { f.style.backgroundColor = ''; });
            this.style.backgroundColor = '#e8f4f8';
        });
    });

    var btnCerrarSec = document.getElementById('btnCerrarSec');
    if (btnCerrarSec) {
        btnCerrarSec.addEventListener('click', function() {
            window.BaxenShell.navigate('/', true);
        });
    }
})();
</script>
