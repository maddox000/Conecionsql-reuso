            </div>
            
            <div style="grid-column: 1/-1;">
                <label style="display: flex; align-items: center; gap: 8px; font-weight: 600; font-size: 0.85rem; color: #666; cursor: pointer;">
                    <input type="checkbox" id="nuevoProductoControlado" name="controlado" style="width: 18px; height: 18px; cursor: pointer;"/>
                    <span>Controlado</span>
                </label>
            </div>
            
            <div style="grid-column: 1/-1;">
                <label style="display: flex; align-items: center; gap: 8px; font-weight: 600; font-size: 0.85rem; color: #666; cursor: pointer;">
                    <input type="checkbox" id="nuevoProductoOculto" name="oculto" style="width: 18px; height: 18px; cursor: pointer;"/>
                    <span>Ocultar</span>
                </label>
            </div>
            
            <div style="grid-column: 1/-1; display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 10px;">
                <button type="submit" style="padding: 12px; background-color: #2c3e50; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: 600; font-size: 0.9rem;">Guardar Producto</button>
                <button type="button" id="btnCancelarProducto" onclick="document.getElementById('modalNuevoProducto').style.display='none';" style="padding: 12px; background-color: #7f8c8d; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: 600; font-size: 0.9rem;">Cancelar</button>
            </div>
        </form>
    </div>
</div>

<!-- Modal para editar producto -->
<div id="modalEditarProducto" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
    <div style="background: white; border-radius: 8px; padding: 30px; max-width: 600px; width: 90%; max-height: 90vh; overflow-y: auto; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
        <h3 style="margin-top: 0; margin-bottom: 20px; color: #2c3e50; font-weight: 600;">Editar Producto</h3>
        
        <form id="formEditarProducto" onsubmit="return false;" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
            <input type="hidden" id="editarProductoId" />
            
            <div>
                <label style="display: block; font-weight: 600; font-size: 0.85rem; color: #666; margin-bottom: 5px;">Código Producto *</label>
